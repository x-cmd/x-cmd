}
}
,
"#tldr"
:
[
{
"cmd"
:
"x shortcut rename m mcli"
,
"cn"
:
"将 m 重命名为 mcli"
,
"en"
:
"Rename shortcut m to mcli"
}
,
{
"cmd"
:
"x shortcut rename --platform darwin m mcli"
,
"cn"
:
"在 darwin 系统下将 m 重命名为 mcli"
,
"en"
:
"Rename shortcut m to mcli on darwin system"
}
,
{
"cmd"
:
"x shortcut rename --by x-cmd mac m"
,
"cn"
:
"将所有 x-cmd 为 mac 的短名重命名为 m"
,
"en"
:
"Rename all shortcuts with x-cmd mac to m"
}
]
}
,
