"x shortcut ls --x-cmd"
,
"cn"
:
"列出所有 x-cmd 相关的短名"
,
"en"
:
"List all x-cmd related shortcuts"
}
,
{
"cmd"
:
"x shortcut ls --field name"
,
"cn"
:
"按名称字段列出短名"
,
"en"
:
"List shortcuts by name field"
}
]
}
,
"rename"
:
{
"#desc"
:
{
"cn"
:
