{
"#name"
:
{
"shortcut"
:
null
,
"cn"
:
"跨 Shell 别名管理器"
,
"en"
:
"Cross-Shell Alias Manager"
}
,
"#desc"
:
{
"cn"
:
"一次配置，永久生效。支持 ash、bash、csh、dash、elvish、fish、nu、xonsh 等主流 Shell。\n设置短名替代长命令，如 `xd` 替代 `x docker`，`ll` 替代 `ls -lah`。\n"
,
"en"
:
"One-time configuration, permanent effect. Supports ash, bash, csh, dash, elvish, fish, nu, xonsh and more.\nSet short names to replace long commands, like `xd` for `x docker`, `ll` for `ls -lah`.\n"
}
,
"#tip"
:
[
{
"en"
:
"- Shortcuts are stored in a YAML config file and compiled to shell-specific code\n- Use `x shortcut set --x-cmd <cmd>` to create x-cmd integrated shortcuts\n- Use `x shortcut compile <shell>` to generate shell-specific alias code\n- Use `x shortcut ls` to view all shortcuts\n"
,
"cn"
:
"- 短名存储在 YAML 配置文件中，编译生成各 Shell 专用代码\n- 使用 `x shortcut set --x-cmd <cmd>` 创建 x-cmd 集成的短名\n- 使用 `x shortcut compile <shell>` 编译生成对应 Shell 的别名代码\n- 使用 `x shortcut ls` 查看所有短名\n"
}
]
,
"#subcmd:core"
:
[
"ls"
,
"get"
,
"cat"
]
,
"#subcmd:edit"
:
[
"set"
,
"unset"
,
"enable"
,
"disable"
,
"rename"
]
,
"#subcmd:system"
:
[
"compile"
,
"default"
,
"default_merge"
,
"init"
]
,
"set"
:
{
"#desc"
:
{
"cn"
:
"设置短名和指向的命令字符串"
,
"en"
:
"Set the shortcut name and its target command string"
}
,
"--platform"
:
{
"#desc"
:
{
"cn"
:
"限制短名只在指定平台生效"
,
"en"
:
"Restrict shortcut to specific platform only"
}
,
"#1"
:
{
"$ref"
:
"x-advise://shortcut/data/platform.jso"
}
}
,
"--cmd"
:
{
"#desc"
:
{
"cn"
:
"指定短名执行的命令，不可与 \"--x-cmd\" 同时使用"
,
"en"
:
"Specify the command to execute for the shortcut. Cannot be used with \"--x-cmd\" at the same time"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"命令"
,
"en"
:
"Command"
}
}
}
,
"--x-cmd"
:
{
"#desc"
:
{
"cn"
:
"指定短名执行的 x-cmd 模块命令，不可与 \"--cmd\" 同时使用"
,
"en"
:
"Specify the x-cmd module command for the shortcut. Cannot be used with \"--cmd\" at the same time"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"x-cmd 模块命令"
,
"en"
:
"x-cmd module command"
}
}
}
,
"--category"
:
{
"#desc"
:
{
"cn"
:
"指定短名的类别"
,
"en"
:
"Specify the category of the shortcut name"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"类别名称"
,
"en"
:
"Category name"
}
}
}
,
"--advise"
:
{
"#desc"
:
{
"cn"
:
"指定短名指向的 advise 补全文件"
,
"en"
:
"Specify the advise completion file for the shortcut name"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"advise 补全文件路径"
,
"en"
:
"advise completion file path"
}
,
"#exec"
:
"___x_cmd_advise__file"
}
}
,
"--status"
:
{
"#desc"
:
{
"cn"
:
"指定短名的状态"
,
"en"
:
"Specify the status of the shortcut name"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"状态"
,
"en"
:
"Status"
}
,
"#cand"
:
[
"enable"
,
"disable"
]
}
}
,
"#tldr"
:
[
{
"cmd"
:
"x shortcut set --x-cmd docker xd"
,
"cn"
:
"设置 xd 为指向执行 `x docker` 的短名"
,
"en"
:
"Set `xd` as a shortcut for `x docker`"
}
,
{
"cmd"
:
"x shortcut set --x-cmd mac m"
,
"cn"
:
"设置 m 为指向执行 `x mac` 的短名"
,
"en"
:
"Set `m` as a shortcut for `x mac`"
}
,
{
"cmd"
:
"x shortcut set --cmd 'ls -lah' ll"
,
"cn"
:
"设置 ll 为指向执行 `ls -lah` 的短名"
,
"en"
:
"Set `ll` as a shortcut for `ls -lah`"
}
,
{
"cmd"
:
"x shortcut set --x-cmd 'docker ps' dps"
,
"cn"
:
"设置 dps 为指向执行 `x docker ps` 的短名"
,
"en"
:
"Set `dps` as a shortcut for `x docker ps`"
}
,
{
"cmd"
:
"x shortcut set --cmd 'git status' gs"
,
"cn"
:
"设置 gs 为指向执行 `git status` 的短名"
,
"en"
:
"Set `gs` as a shortcut for `git status`"
}
,
{
"cmd"
:
"x shortcut set --cmd 'git log --oneline -20' gl"
,
"cn"
:
"设置 gl 为指向执行 `git log --oneline -20` 的短名"
,
"en"
:
"Set `gl` as a shortcut for `git log --oneline -20`"
}
,
{
"cmd"
:
"x shortcut set --advise x-advise://docker/advise.jso xd"
,
"cn"
:
"设置 xd 的 advise 补全文件"
,
"en"
:
"Set the advise completion file for `xd`"
}
,
{
"cmd"
:
"x shortcut set --category openai --x-cmd openai chat"
,
"cn"
:
"在 openai 类别下设置 chat 短名"
,
"en"
:
"Set chat shortcut under openai category"
}
]
}
,
