}
}
,
"#tldr"
:
[
{
"cmd"
:
"x shortcut unset mac"
,
"cn"
:
"删除名称为 mac 的短名"
,
"en"
:
"Delete the shortcut named mac"
}
,
{
"cmd"
:
"x shortcut unset --platform darwin m"
,
"cn"
:
"删除 darwin 系统下的 m 短名"
,
"en"
:
"Delete the shortcut m on darwin system"
}
,
{
"cmd"
:
"x shortcut unset --by x-cmd mac"
,
"cn"
:
"删除所有 x-cmd 字段为 mac 的短名"
,
"en"
:
"Delete all shortcuts by x-cmd field equal to mac"
}
,
{
"cmd"
:
"x shortcut unset --by cmd 'ls -lah'"
,
"cn"
:
"删除所有指向 `ls -lah` 命令的短名"
,
"en"
:
"Delete all shortcuts pointing to `ls -lah`"
}
,
{
"cmd"
:
"x shortcut unset --by category openai"
,
"cn"
:
"删除 openai 类别下的所有短名"
,
"en"
:
"Delete all shortcuts in the openai category"
}
]
}
