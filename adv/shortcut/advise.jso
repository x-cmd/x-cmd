:
"按名称查看短名状态"
,
"en"
:
"View shortcut status grouped by word"
}
,
{
"cmd"
:
"x shortcut status --by platform"
,
"cn"
:
"按平台查看短名状态"
,
"en"
:
"View shortcut status grouped by platform"
}
]
}
,
"ls"
:
{
"#desc"
:
{
"cn"
:
"列出所有短名"
