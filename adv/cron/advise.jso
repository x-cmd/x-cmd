}
,
"--ns"
:
{
"#desc"
:
{
"cn"
:
"指定命名空间（默认 DEFAULT）"
,
"en"
:
"Specify the namespace (default DEFAULT)"
}
,
"#1"
:
null
}
,
"--tsv"
:
{
"#desc"
:
{
"cn"
:
