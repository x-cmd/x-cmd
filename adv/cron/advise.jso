}
,
"--ns"
:
{
"#desc"
:
{
"cn"
:
"指定命名空间（默认 DEFAULT）"
,
"en"
:
"Specify the namespace (default DEFAULT)"
}
,
"#1"
:
null
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"任务名称"
,
"en"
:
"Job name"
}
}
}
,
"ls|list"
:
{
"#desc"
:
{
"cn"
:
"列出当前命名空间下的所有任务（TSV 格式：名称 表达式 描述）"
,
"en"
