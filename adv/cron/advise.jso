"立即执行当前时间匹配的所有任务（单次执行，不循环）"
,
"en"
:
"Execute all jobs matching the current time once (no loop)"
}
,
"--ns"
:
{
"#desc"
:
{
"cn"
:
"指定命名空间（默认 DEFAULT）"
,
"en"
:
"Specify the namespace (default DEFAULT)"
}
,
"#1"
:
null
}
,
"--fp"
:
{
"#desc"
:
{
"cn"
:
"指定任务列表目录路径"
,
"en"
:
"Specify the job list directory path"
}
,
"#1"
:
null
}
}
,
