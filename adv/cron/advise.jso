"Auto-detect output format"
}
}
}
,
"match"
:
{
"#desc"
:
{
"cn"
:
"测试指定时间是否匹配 cron 表达式（默认使用当前时间）"
,
"en"
:
"Test if a time matches a cron pattern (uses current time by default)"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"cron 时间表达式"
,
"en"
:
"Cron time expression"
}
}
,
"#2"
:
{
"#desc"
:
{
"cn"
:
"测试时间（格式：分 时 日 月 星期），省略则使用当前时间"
,
"en"
:
"Time to test (format: min hour day month dow), defaults to current time"
}
}
}
,
"tz"
:
{
"#desc"
:
{
"cn"
:
"设置或查看命名空间的时区"
,
"en"
:
"Set or read timezone for a namespace"
}
,
"--ns"
:
{
"#desc"
:
{
"cn"
:
"指定命名空间（默认 DEFAULT）"
,
"en"
:
"Specify the namespace (default DEFAULT)"
}
,
"#1"
:
null
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"时区名称（如 Asia/Shanghai），省略则查看当前时区"
,
"en"
:
"Timezone name (e.g. Asia/Shanghai), omit to read current timezone"
}
}
}
,
"run"
:
{
"#desc"
:
{
"cn"
:
"前台运行 cron 守护进程（循环执行，每分钟检查并运行匹配任务）"
,
"en"
:
"Run the cron daemon in the foreground (loop, check and run matching jobs every minute)"
}
,
"--ns"
:
{
"#desc"
:
{
"cn"
:
"指定命名空间（默认 DEFAULT）"
,
"en"
:
"Specify the namespace (default DEFAULT)"
}
,
"#1"
:
null
}
,
