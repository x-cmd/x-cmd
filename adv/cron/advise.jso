:
{
"#desc"
:
{
"cn"
:
"只执行一次，执行后自动删除"
,
"en"
:
"Run only once, auto-delete after execution"
}
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"cron 时间表达式（分钟 小时 日 月 星期）"
,
"en"
:
"Cron time expression (min hour day month dow)"
}
}
,
"#2"
:
{
"#desc"
:
{
"cn"
:
"要执行的命令"
,
"en"
:
"Command to execute"
}
}
}
,
"rm"
:
{
"#desc"
:
{
"cn"
:
"删除指定任务"
,
"en"
