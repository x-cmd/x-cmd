{
"#useparam"
:
true
,
"#desc"
:
{
"cn"
:
"使用机器人在 slack 上发送消息。"
,
"en"
:
"using bots to send messages on slack."
}
,
"webhook"
:
{
"#desc"
:
{
"cn"
:
"设置 webhook url"
,
"en"
:
"set webhook url"
}
,
"#tldr"
:
[
{
"cmd"
:
"x slack webhook get"
,
"cn"
:
"获取 webhook url"
,
"en"
:
"get webhook url"
}
,
{
"cmd"
:
"x slack webhook set xxxx"
,
"cn"
:
"设置 webhook url 为 xxxx"
,
"en"
:
"set the webhook url to xxxx"
}
,
{
"cmd"
:
"x slack webhook unset"
,
"cn"
:
"重置 webhook url"
,
"en"
:
"unset webhook url"
}
]
}
,
"send"
:
{
"#desc"
:
{
"cn"
:
"发送消息到 slack"
,
"en"
:
"Send message to slack"
}
,
"#synopsis"
:
[
{
"cmd"
:
"x slack send <msg type>"
,
"cn"
:
"发送消息的类型"
,
"en"
:
"The type of message to send"
}
]
,
"#tldr"
:
[
{
"cmd"
:
"x slack send text hello"
,
"cn"
:
"发送 hello 到 slack"
,
"en"
:
"Send hello to slack"
}
,
{
"cmd"
:
"x slack send image --text <content> --image_url <image_url> --alt_text <alt_text>"
,
"cn"
:
"发送图片到 slack"
,
"en"
:
"Send image to slack"
}
]
,
"raw"
:
{
"#tldr"
:
[
{
"cmd"
:
"x slack send raw - <<A \n  {\n      \"text\": \"hello\"\n  }\n  A"
,
"cn"
:
"发送 hello 到slack"
,
"en"
:
"Send hello to slack"
}
]
}
,
"section"
:
{
"#tldr"
:
[
{
"cmd"
:
"x slack send section --section \"mrkdwn\" \"**hello**\""
,
"cn"
:
"发送粗体字 hello 到slack"
,
"en"
:
"Send hello in bold to slack"
}
]
}
,
"context"
:
{
"#tldr"
:
[
{
"cmd"
:
"x slack send context --text \"plain_text\" <content> --image <image_url> <alt_text>"
,
"cn"
:
"发送上下文消息到 slack"
,
"en"
:
"Send context message to slack"
}
]
}
,
"action"
:
{
"#tldr"
:
[
{
"cmd"
:
"x slack send action --section \"mrkdwn\" <content> --accessory <content> <url>"
,
"cn"
:
"发送点击按钮可跳转的信息"
,
"en"
:
"Send message that you can jump to with the click of a button"
}
]
}
,
"image"
:
{
"#tldr"
:
[
{
"cmd"
:
"x slack send image --text <content> --image_url <image_url> --alt_text <alt_text>"
,
"cn"
:
"发送图片到 slack"
,
"en"
:
"Send image to slack"
}
]
}
,
"video"
:
{
"#tldr"
:
[
{
"cmd"
:
"x slack send video\n  --tit_text \"youtube\"\n  --title_url \"https://www.youtube.com/watch?v=RRxQQxiM7AA\"\n  --desc_text \"Slack is a new way to communicate with your team\"\n  --video_url \"https://www.youtube.com/embed/RRxQQxiM7AA?feature=oembed&autoplay=1\"\n  --alt_text \"test1\"\n  --thumbnail_url \"https://i.ytimg.com/vi/RRxQQxiM7AA/hqdefault.jpg\"\n  --author_name \"Arcado Buendia\"\n  --provider_name \"YouTube\"\n  --provider_icon_url \"https://a.slack-edge.com/80588/img/unfurl_icons/youtube.png\""
,
"cn"
:
"发送以上参数值的视频消息到slack"
,
"en"
:
"Send video message with the above parameter values to Slack"
}
]
}
}
,
