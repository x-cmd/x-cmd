"Initialize configuration service provider short name and set proxy"
}
,
"--http"
:
{
"#desc"
:
{
"cn"
:
"使用 http 协议设置代理"
,
"en"
:
"Setup proxy using the http protocol"
}
,
"#1"
:
null
}
,
"--ssh"
:
{
"#desc"
:
{
"cn"
:
"使用 SSH 协议设置代理"
,
"en"
:
"Setup proxy using the SSH protocol"
}
,
"#1"
:
null
}
,
"--proxy"
:
{
"#desc"
:
{
"cn"
:
"同时使用 http 和 SSH 协议设置代理"
,
"en"
:
"Setup proxy using both http and SSH protocols"
}
,
"#1"
:
null
}
,
"#tldr"
:
[
{
"cmd"
:
"x git sp setup localhost:9999\n"
,
"cn"
:
"对 github,gitlab,codeberg,bitbucket 设置 http, https, socks5 代理，地址为 localhost:9999；这是最为常用的场景"
,
"en"
:
"Set http, https, and socks5 proxies for github, gitlab, codeberg, and bitbucket, with the address localhost:9999；This is the most common scenario"
}
,
{
"cmd"
:
"x git sp setup --http socks5://localhost:9999 --ssh localhost:9999\n"
,
"cn"
:
"设置短名和使用 http、SSH 协议设置代理"
,
"en"
:
"Setting up short names and configuring proxies using HTTP/SSH"
}
]
}
,
"cleanup"
:
{
"#desc"
:
{
"cn"
:
"清除 setup 设置的内容"
