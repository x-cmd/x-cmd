:
{
"#desc"
:
{
"cn"
:
"将秒数转为可读时间格式（如 3600 → 1h）"
,
"en"
:
"Convert seconds to readable format (e.g., 3600 → 1h)"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"秒数（支持小数，如 3661.5）"
,
"en"
:
"Seconds (supports fractional, e.g., 3661.5)"
}
}
,
