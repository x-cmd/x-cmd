"#tldr"
:
[
{
"cmd"
:
"x install"
,
"en"
:
"Open interactive UI to search, browse, and install software and skills"
,
"cn"
:
"打开交互式界面，搜索、浏览并安装软件和 skill"
}
,
{
"cmd"
:
"x install bun vim"
,
"en"
:
"Interactively select and install bun and vim"
,
"cn"
:
"交互式选择并安装 bun 和 vim"
}
,
{
"cmd"
:
"x install skill/anthropics/pptx clawhub/skill-vetter"
,
"en"
:
"Install skills from skill/* or clawhub/* format"
,
"cn"
:
"安装 skill（skill/* 或 clawhub/* 格式）"
}
,
{
"cmd"
:
"x install --best bun"
,
"en"
:
"Automatically select the best method to install bun"
,
"cn"
:
"自动选择最佳方式安装 bun"
}
,
{
"cmd"
:
"x install --best --priority brew,xpkg bun"
,
"en"
:
"Install bun with brew as priority, falling back to xpkg"
,
"cn"
:
"优先使用 brew 安装 bun，其次 xpkg"
}
,
{
"cmd"
:
"x install --withtool brew vim bun"
,
"en"
:
"Install vim and bun using brew"
,
"cn"
:
"使用 brew 安装 vim 和 bun"
}
,
{
"cmd"
:
"x install --best --printcmd bun"
,
"en"
:
"Preview the best install command for bun without executing"
,
"cn"
:
"预览安装 bun 的最佳命令但不执行"
}
,
{
"cmd"
:
"x install --withtool brew --printcmd bun"
,
"en"
:
"Preview brew install command for bun without executing"
,
"cn"
:
"预览 brew 安装 bun 的命令但不执行"
}
,
{
"cmd"
:
"x install --printinfo bun"
,
"en"
:
"Print detailed information and all installation methods for bun"
,
"cn"
:
"打印 bun 的详细信息和所有安装方法"
}
,
{
"cmd"
:
"x install --printinfo --json bun"
,
"en"
:
"Output bun info in JSON format for AI agents"
,
"cn"
:
"以 JSON 格式输出 bun 信息供 AI Agent 使用"
}
,
{
"cmd"
:
"x install --search ppt"
,
"en"
:
"Search for software and skills across multiple sources"
,
"cn"
:
"从多个软件源和 skill 平台搜索"
}
,
{
"cmd"
:
"x install --env"
,
"en"
:
"Print current system environment info"
,
"cn"
:
"打印当前系统环境信息"
}
,
{
"cmd"
:
"x install --ls"
,
"en"
:
"List all software recorded in the install module"
,
"cn"
:
"列出 install 模块收录的所有软件"
}
,
{
"cmd"
:
"x install --available-tool"
,
"en"
:
"List all package managers supported in current environment"
,
"cn"
:
"列出当前环境支持的所有包管理器"
}
,
{
"cmd"
:
"x install --update"
,
"en"
:
"Update the resource files of x install"
,
"cn"
:
"更新 x install 的资源文件"
}
]
