}
,
"#1"
:
{
"#desc"
:
{
"en"
:
"Software name to query"
,
"cn"
:
"要查询的软件名"
}
,
"#exec:stdout"
:
"xrc install; ___x_cmd_install_ls___name"
}
,
"--json"
:
{
"#desc"
:
{
"en"
:
"Output in JSON format (for AI Agent)"
,
"cn"
:
"以 JSON 格式输出（供 AI Agent 使用）"
}
}
,
"--yml"
:
{
"#desc"
:
{
"en"
:
"Output in YAML format"
,
"cn"
:
