"code"
:
{
"#desc"
:
{
"cn"
:
"查看代码参考表，用于构建动态别名。详情: x dbnomics code --help"
,
"en"
:
"View code reference tables for building dynamic aliases. Details: x dbnomics code --help"
}
,
"#tldr"
:
[
{
"cmd"
:
"x dbnomics code region2"
,
"cn"
:
"国家代码表（2字母 → IMF WEO 3字母，用于 imf.<cc>.* 别名）"
,
"en"
:
"Country codes (2-letter to IMF WEO 3-letter, for imf.<cc>.* aliases)"
}
,
{
"cmd"
:
"x dbnomics code weoseries"
,
"cn"
:
"IMF WEO 指标后缀表（用于 imf.*.<suffix> 别名）"
,
"en"
:
"IMF WEO indicator suffixes (for imf.*.<suffix> aliases)"
}
,
{
"cmd"
:
"x dbnomics code currency"
,
"cn"
:
"货币代码表（ISO 4217 → BIS pair，用于 bis.<currency> 别名）"
,
"en"
:
"Currency codes (ISO 4217 to BIS pair, for bis.<currency> aliases)"
}
,
{
"cmd"
:
"x dbnomics code cbpol"
,
"cn"
:
"央行利率国家代码表（用于 bis.rate.<cc> 别名）"
,
"en"
:
"Central bank rate country codes (for bis.rate.<cc> aliases)"
}
,
{
"cmd"
:
"x dbnomics code weoagg"
,
"cn"
:
"经济联盟代码表（用于 imf.<group>.* 别名，如 eu、g7、asean）"
,
"en"
:
"Economic group codes (for imf.<group>.* aliases, e.g. eu, g7, asean)"
}
]
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"代码表名称 (region2, weoseries, currency, cbpol, weoagg)"
,
"en"
:
"Code table name (region2, weoseries, currency, cbpol, weoagg)"
}
,
"#cand"
:
[
"region2"
,
"weoseries"
,
"currency"
,
"cbpol"
,
"weoagg"
]
}
}
}

