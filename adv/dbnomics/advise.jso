,
"index"
:
{
"#desc"
:
{
"cn"
:
"生成和查询本地数据集索引"
,
"en"
:
"Generate and query local dataset index"
}
,
"#tldr"
:
[
{
"cmd"
:
"x dbnomics index generate"
,
"cn"
:
"示例: 从远程下载完整数据集索引"
,
"en"
:
"Example: Download full dataset index from remote"
}
,
{
"cmd"
:
"x dbnomics index ls"
,
"cn"
:
"示例: 列出所有已索引的数据集"
,
"en"
:
"Example: List all indexed datasets"
}
,
{
"cmd"
:
"x dbnomics index ls GDP"
,
"cn"
:
"示例: 搜索含 GDP 的数据集"
,
"en"
:
"Example: Search datasets containing GDP"
}
,
{
"cmd"
:
"x dbnomics index ls | grep Eurostat | head -20"
,
"cn"
:
"示例: 用 grep 过滤 Eurostat 数据集"
,
"en"
:
"Example: Filter Eurostat datasets with grep"
}
]
}
,
