{
"#name"
:
{
"disk"
:
{
"en"
:
"Disk information, filesystem usage, and partition listing"
,
"cn"
:
"磁盘信息、文件系统使用率和分区列表"
}
}
,
"#synopsis"
:
[
{
"x disk [subcommand]"
:
null
}
,
{
"x disk"
:
null
}
,
{
"x disk info"
:
null
}
,
{
