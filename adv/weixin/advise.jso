}
,
"clear"
:
{
"#desc"
:
{
"cn"
:
"清除当前会话设置的默认值，恢复为配置记录默认值"
,
"en"
:
"Clear all session-set defaults, revert to config defaults"
}
}
,
"ls"
:
{
"#desc"
:
{
"cn"
:
"罗列当前会话设置的所有默认值"
,
"en"
:
