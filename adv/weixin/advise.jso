}
}
}
,
"--cfg"
:
{
"#desc"
:
{
"cn"
:
"微信配置管理"
,
"en"
:
"WeChat configuration management"
}
,
"#tip:note"
:
[
{
"en"
:
"WeChat iLink bot configuration. You need bot_token, account_id, and base_url after QR login.\n"
,
"cn"
:
"微信 iLink 机器人配置。QR 码登录后需要保存 bot_token、account_id 和 base_url。\n"
}
]
,
"#tldr"
:
[
{
"cmd"
:
"x weixin --cfg token=<bot_token> account_id=<account_id> base_url=<base_url>"
,
"cn"
:
"设置机器人配置"
,
"en"
:
"Set bot configuration"
}
]
,
