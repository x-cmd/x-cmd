}
}
}
,
"--name"
:
{
"#desc"
:
{
"cn"
:
"指定 Worker 名称"
,
"en"
:
"Specify worker name"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"Worker 名称"
,
"en"
:
"Worker name"
}
}
}
}
,
