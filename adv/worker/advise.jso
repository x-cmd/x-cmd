:
"指定 Worker 名称"
,
"en"
:
"Specify worker name"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"Worker 名称"
,
"en"
:
"Worker name"
}
}
}
}
,
"info"
:
{
"#desc"
:
{
"cn"
:
"显示 Worker 详细信息"
,
"en"
:
"Show worker details"
}
,
"#tip"
:
[
{
"cn"
:
"输出包含 PID、指纹、启动时间、状态（ongoing 表示运行中，done 表示已结束）；从 runner.$name/_PIDFILE 读取"
,
"en"
:
"Output includes PID, fingerprint, start time, state (ongoing means running, done means finished); reads from runner.$name/_PIDFILE"
}
]
,
"--ns"
:
{
"#desc"
:
{
"cn"
:
