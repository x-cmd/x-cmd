:
{
"#desc"
:
{
"cn"
:
"使用企业微信群机器人发送消息"
,
"en"
:
"Send messages using a WXwork group bot"
}
,
"send"
:
{
"#desc"
:
{
"cn"
:
"使用企业微信群机器人发送消息"
,
"en"
:
"Send messages using a WXwork group bot"
}
,
"$ref"
:
"x-advise://qywx/data/send.jso"
}
}
,
"send"
:
{
"#subcmd"
:
true
,
"#desc"
:
{
"cn"
:
"使用企业微信群机器人发送消息（等同于 x qywx bot send）"
,
"en"
:
"Send messages using a WXwork group bot (equivalent to `x qywx bot send`)"
}
,
"$ref"
:
"x-advise://qywx/data/send.jso"
}
,
"abot"
:
{
"#desc"
:
{
"cn"
:
"使用企业微信智能机器人发送消息和管理监听服务"
,
"en"
:
"Send messages and manage listener service using WXwork intelligent bot"
}
,
"#tldr"
:
[
{
"cmd"
:
"x qywx abot send --text --chatid <chat_id> \"Hello\""
,
"cn"
:
"使用智能机器人发送文本消息"
,
"en"
:
"Send text messages using intelligent bot"
}
,
{
"cmd"
:
"x qywx abot service start"
,
"cn"
:
"启动智能机器人监听服务"
,
"en"
:
"Start the intelligent bot listener service"
}
,
{
"cmd"
:
"x qywx abot data which <chat_id>"
,
"cn"
:
"查看指定会话的数据文件路径"
,
"en"
:
"Show data file path for specified chat"
}
]
,
"send"
:
{
"#desc"
:
{
"cn"
:
