"react"
:
{
"#desc"
:
{
"cn"
:
"监听企业微信消息，根据指定模式自动回复消息"
,
"en"
:
"Listen for WXwork messages and reply automatically based on the specified mode"
}
,
"#tldr"
:
[
{
"cmd"
:
"x qywx react"
,
"cn"
:
"启动默认模式（echo模式），原文返回"
,
"en"
:
"Start in default mode (echo), returning the original message"
}
,
{
"cmd"
:
"x qywx react --runner repl"
,
"cn"
:
"启动交互式指令模式，将收到的消息作为命令执行并返回结果"
,
"en"
:
"Start interactive REPL mode, executing messages as commands and returning output"
}
,
{
"cmd"
:
"x qywx react --runner echo"
,
"cn"
:
"启动简单回显服务，测试通信是否正常"
,
"en"
:
"Start a simple echo service to test if communication is working"
}
]
,
"--timeout"
:
{
"#synopsis"
:
"<ms>"
,
"#desc"
:
{
"cn"
:
"响应器超时时间"
,
"en"
:
"Timeout for the message reactor"
}
,
"#1"
:
null
}
,
"--runner"
:
{
"#synopsis"
:
"<name>"
,
"#desc"
:
{
"cn"
:
"响应器运行模式"
,
"en"
:
"The execution mode of the reactor"
}
,
"#1"
:
{
"#cand"
:
[
{
"echo"
:
{
"#desc"
:
{
"cn"
:
"Echo 模式，直接返回原消息内容"
,
"en"
:
"Echo mode, returns the original message content directly"
}
}
}
,
{
"repl"
:
{
"#desc"
:
{
"cn"
:
"REPL 模式，将消息视为命令执行并返回输出"
,
"en"
:
"REPL mode, treats messages as commands and returns their execution output"
}
}
}
]
}
}
}
,
"listen"
:
{
"#desc"
:
{
"cn"
:
"监听企业微信消息（WebSocket 长连接）"
,
"en"
:
"Listen for WXwork messages via WebSocket long connection"
}
,
"#tldr"
:
[
{
"cmd"
:
"x qywx listen"
,
"cn"
:
"启动监听（输出到 stdout）"
,
"en"
:
"Start listening (output to stdout)"
}
,
{
"cmd"
:
"x qywx listen --json"
,
"cn"
:
"以 JSON 格式输出消息"
,
"en"
:
"Output messages in JSON format"
}
,
{
"cmd"
:
"x qywx listen --fp"
,
"cn"
:
"启动监听并保存消息到文件"
,
"en"
:
"Start listening and save messages to file"
}
]
,
"--fp"
:
{
"#desc"
:
{
"cn"
:
"保存消息到文件（用于 abot 服务）"
,
"en"
:
"Save messages to file (for abot service)"
}
}
,
"--json"
:
{
"#desc"
:
{
"cn"
:
"以 JSON 格式输出"
,
"en"
:
"Output in JSON format"
}
}
}
,
"init"
:
{
"#desc"
:
{
"en"
:
"Initialize the configuration using interactive mode"
,
"cn"
:
"使用交互模式初始化配置"
}
}
,
"--cur"
:
{
"#desc"
:
{
