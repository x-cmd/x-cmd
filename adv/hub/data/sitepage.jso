:
[
{
"cmd"
:
"x hub site update <siteId> <file>"
,
"cn"
:
"为站点上传新版本"
,
"en"
:
"Upload a new version for the site"
}
,
{
"cmd"
:
"x hub site update --data <json> <siteId> <file>"
,
"cn"
:
"上传新版本并更新结构化数据"
,
"en"
:
"Upload a new version with updated structured data"
}
]
}
,
"rollback"
:
{
"#desc"
:
{
"cn"
:
"将站点回滚到指定的历史版本。切换当前展示版本，分享链接不变。\n先用 `x hub site info <siteId>` 查看 versions 列表获取目标 versionId。\n"
,
"en"
:
"Roll back the site to a specified historical version. Switches the current displayed version, share URL remains unchanged.\nUse `x hub site info <siteId>` first to get the versionId from the versions list.\n"
}
,
"--version|-v"
:
{
"#desc"
:
{
"cn"
:
"目标版本 ID（从 `x hub site info` 的 versions 列表获取）"
,
"en"
:
"Target version ID (from the versions list in `x hub site info`)"
}
,
"#1"
:
null
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"站点 ID"
,
"en"
:
"Site ID"
}
}
,
"#tldr"
:
[
{
"cmd"
:
"x hub site rollback <siteId> --version <versionId>"
,
"cn"
:
"将站点回滚到指定版本"
,
"en"
:
"Roll back the site to the specified version"
}
]
}
,
