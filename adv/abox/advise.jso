:
[
"tmux|t"
,
"cmd"
,
"cmdi"
,
"login"
]
,
"#tldr"
:
[
{
"cmd"
:
"x abox start"
,
"cn"
:
"启动默认容器（无 SSH）"
,
"en"
:
"Start default container (no SSH)"
}
,
{
"cmd"
:
"x abox start --pass - --port 2222"
,
"cn"
:
"启动容器并启用 SSH（随机密码）"
,
"en"
:
"Start container with SSH (random password)"
}
,
{
"cmd"
:
"x abox start --key ~/.ssh/id_rsa.pub --port 2222 -n mybox"
,
"cn"
:
"使用 SSH 公钥启动命名容器"
,
"en"
:
"Start named container with SSH key"
}
,
{
"cmd"
:
"x abox rm"
,
"cn"
:
"删除默认容器"
,
"en"
:
"Remove default container"
}
,
{
"cmd"
:
"x abox ls"
,
"cn"
:
"列出所有 abox 容器"
,
"en"
:
"List all abox containers"
}
,
{
"cmd"
:
"x abox t"
,
"cn"
:
"通过 tmux 连接到默认容器"
,
"en"
:
"Connect to default container via tmux"
}
,
{
"cmd"
:
"x abox tmux :claude"
,
"cn"
:
"在容器中启动名为 claude 的 tmux 会话"
,
"en"
:
"Start tmux session named 'claude' in container"
}
,
{
"cmd"
:
"x abox stop"
,
"cn"
:
"停止默认容器"
,
"en"
:
"Stop default container"
}
,
{
"cmd"
:
"x abox pause"
,
"cn"
:
"暂停默认容器"
,
"en"
:
"Pause default container"
}
,
{
"cmd"
:
"x abox resume"
,
"cn"
:
"恢复默认容器"
,
"en"
:
"Resume default container"
}
,
{
"cmd"
:
"x abox cmdi bash"
,
"cn"
:
"在默认容器中启动交互式 bash"
,
"en"
:
"Start interactive bash in default container"
}
,
{
"cmd"
:
"x abox clearall"
,
"cn"
:
"清理所有 abox 容器和镜像"
,
"en"
:
"Clean up all abox containers and images"
}
]
}

