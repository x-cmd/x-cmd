"#tip"
:
[
{
"cn"
:
"如果不指定容器名称，默认重启名为 \"abox-0\" 的容器。\n"
,
"en"
:
"If no container name is specified, restarts the container named \"abox-0\" by default.\n"
}
]
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"容器名称（可选，默认为 abox-0）"
,
"en"
:
"Container name (optional, defaults to abox-0)"
}
}
,
"#tldr"
:
[
