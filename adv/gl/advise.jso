"cl"
:
{
"#desc"
:
{
"en"
:
"shortcut for `x gl repo clone`"
,
"cn"
:
"`x gl repo clone` 的简写别名"
}
,
"$ref"
:
"x-advise://git/data/clone.jso"
,
"#1"
:
{
"#desc"
:
{
"en"
:
"<ownerPath>/<repoPath> (default ownerPath: current user)"
,
"cn"
:
"<所属空间地址>/<项目地址> (默认所属空间地址: 当前用户空间地址)"
}
}
}
,
"ddgo|:"
:
{
"#desc"
:
{
"cn"
:
"DuckDuckGo 搜索 GitLab 相关的信息列表"
,
"en"
:
"Search GitLab related information using DuckDuckGo"
}
,
"#tldr"
:
[
{
"cmd"
:
"x gl ddgo convert mkv to mp4 CLI"
,
"cn"
:
"使用 DuckDuckGo 搜索 GitLab 上关于 mkv 转 mp4 的 CLI"
,
"en"
:
"Search for CLI to convert mkv to mp4 on GitLab"
}
]
,
