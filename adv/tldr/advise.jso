"--fz"
:
{
"#subcmd"
:
true
,
"#desc"
:
{
"en"
:
"Using fzf to search and view TLDR pages"
,
"cn"
:
"采用 fzf 搜索和显示 TLDR"
}
,
"$ref"
:
"x-advise://tldr/data/fz.jso"
}
,
"--help|-h"
:
{
"#desc"
:
{
"en"
:
"Show help"
,
"cn"
:
"展示 help 文档"
}
}
,
"#tldr"
:
[
{
"cmd"
:
"x tldr git"
,
"cn"
:
"示例: 查看 git 命令的常用用法"
,
"en"
:
"Example: View common usage of git command"
}
,
{
"cmd"
:
"x tldr git checkout"
,
"cn"
:
"示例: 查看 git checkout 子命令的用法"
,
"en"
:
"Example: View git checkout subcommand usage"
}
,
{
"cmd"
:
"x tldr --fz"
,
"cn"
:
"示例: 使用 fzf 交互式浏览所有 TLDR 文档"
,
"en"
:
"Example: Browse all TLDR docs interactively with fzf"
}
,
{
"cmd"
:
"x tlfz"
,
"cn"
:
"示例: 使用 tlfz 快捷命令启动 fzf 浏览"
,
"en"
:
"Example: Use tlfz shortcut to launch fzf browser"
}
,
{
"cmd"
:
"x tldr --lang zh git"
,
"cn"
:
"示例: 使用简体中文显示 git 文档"
,
"en"
:
"Example: Display git docs in Simplified Chinese"
}
,
{
"cmd"
:
"x tldr --cat python"
,
"cn"
:
"示例: 直接显示 python 的 TLDR 文档内容"
,
"en"
:
"Example: Directly display python TLDR content"
}
,
{
"cmd"
:
"x tldr --which tar"
,
"cn"
:
"示例: 查看 tar 命令文档的文件路径"
,
"en"
:
"Example: View file path of tar command docs"
}
,
{
"cmd"
:
"x tldr --update"
,
"cn"
:
"示例: 更新 TLDR 文档资源包"
,
"en"
:
"Example: Update TLDR documentation resources"
}
]
,
"#subcmd:Query"
:
[
"--app"
,
"--cat"
,
"--which"
,
"--fz"
]
,
"#subcmd:Management"
:
[
"--update|-u"
,
"--lang|-L"
,
"--ls|-l"
,
"--version|-v"
]
,
