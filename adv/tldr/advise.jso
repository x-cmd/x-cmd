:
"查看命令对应的 tldr 文档路径"
}
,
"#1"
:
{
"#desc"
:
{
"en"
:
"Command name, code example name"
,
"cn"
:
"命令名称、代码示例名称"
}
,
"#exec"
:
"xrc tldr; candidate_exec_arr=( $(___x_cmd_tldr_listname \"$cur\") )"
}
}
,
