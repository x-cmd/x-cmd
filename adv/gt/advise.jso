:
{
"#desc"
:
{
"en"
:
"pull request management"
,
"cn"
:
"Pull Request 管理"
}
,
"$ref"
:
"x-advise://gt/data/pr.jso"
}
,
"notification|n"
:
{
"#desc"
:
{
"en"
:
"notification management"
,
"cn"
:
"通知管理"
}
,
"$ref"
:
"x-advise://gt/data/notification.jso"
}
,
"codeurl"
:
{
"#desc"
:
{
"cn"
:
"获取 Gitee 资源地址"
,
"en"
:
"Get Gitee source url"
}
,
"#tldr"
:
[
{
"cmd"
:
"x gt codeurl https://gitee.com/x-cmd/x-cmd"
,
"cn"
:
"获取 x-cmd/x-cmd 仓库默认分支的 README.md 原始文件地址"
,
"en"
:
"Get the raw file URL of the README.md for the default branch of the x-cmd/x-cmd repository"
}
,
{
"cmd"
:
"x gt codeurl https://gitee.com/x-cmd/x-cmd/blob/X/LICENSE/LICENSE.txt"
,
"cn"
:
"获取 x-cmd/x-cmd 仓库 X 分支的 LICENSE/LICENSE.txt 原始文件地址"
,
"en"
:
"Get the raw file URL of LICENSE/LICENSE.txt on branch X of the x-cmd/x-cmd repository"
}
]
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"以 https://codeberg.org 开头的资源地址"
,
"en"
:
"The resource address starting with https://codeberg.org"
}
}
}
,
"avatar"
:
{
"#desc"
:
{
"en"
:
"user addressbook management"
,
"cn"
:
"用户地址薄管理"
}
,
"#tldr"
:
[
{
"cmd"
:
"x gt avatar add <key> <user_path>\nx gt repo collaborator add --repo <owner_repo> <key>\n"
,
"en"
:
"Add the user <user_path> to the addressbook of the current session\nUsing <key> recorded in the address book <user_path> to add the user as a repository collaborator\n"
,
"cn"
:
"添加 user <user_path> 到当前会话的 addressbook\n使用用户地址薄 <key> 记录的 <user_path> 来添加为仓库成员\n"
}
]
,
"ls"
:
{
"#desc"
:
{
"en"
:
"List all address books for the current session record"
,
"cn"
:
"罗列当前会话记录的所有地址薄"
}
,
"--raw"
:
{
"#desc"
:
{
"en"
:
"output format as key=value"
,
"cn"
:
"输出格式为 键=值"
}
}
}
,
"add|put"
:
{
"#desc"
:
{
"en"
:
"Add or Edit the key and value in the address book"
,
"cn"
:
"添加或修改地址薄中的 key 和 value"
}
,
"#synopsis"
:
[
{
"x gt avatar add|put <key> <value>"
:
null
}
]
,
"#1"
:
{
"#desc"
:
{
"en"
:
"address book key"
,
"cn"
:
"地址薄键"
}
}
,
"#2"
:
{
"#desc"
:
{
"en"
:
"address book value"
,
"cn"
:
"地址薄值"
}
}
}
,
"get"
:
{
"#desc"
:
{
"en"
:
"Get the value of the address book record by key"
,
"cn"
:
"通过 key 获取地址薄记录的 value"
}
,
"#1"
:
{
"#desc"
:
{
"en"
:
"address book key"
,
"cn"
:
"地址薄键"
}
}
}
}
,
"--cur"
:
{
"#desc"
:
{
"en"
:
"current session default value management"
,
"cn"
:
"当前会话默认值管理"
}
,
"#tip:note"
:
[
{
"en"
:
"- profile: switch config profile name in current session\n- config: switch config file in current session\n- owner: switch default owner in current session\n- repo: switch default repo in current session\n"
,
"cn"
:
"- profile: 切换当前会话的配置信息名称\n- config: 切换当前会话的配置文件\n- owner: 切换当前会话的默认代码所有者地址\n- repo: 切换当前会话的默认仓库\n"
}
]
,
"clear"
:
{
"#desc"
:
{
"en"
:
"Clear all setting default in the current session and reback the default value of the config record"
,
"cn"
:
"清除当前会话设置的默认值, 恢复为配置记录默认值"
}
}
,
"ls"
:
{
"#desc"
:
{
"en"
:
"List all current value in the session"
,
"cn"
:
"罗列当前会话设置的所有默认值"
}
}
,
"#n"
:
{
"#cand"
:
[
{
"profile="
:
{
"#nospace"
:
true
,
"#desc"
:
{
"en"
:
"switch config profile name in current session"
,
"cn"
:
"切换当前会话的配置信息名称"
}
}
}
,
{
"config="
:
{
"#nospace"
:
true
,
"#desc"
:
{
"en"
:
"switch config file in current session"
,
"cn"
:
"切换当前会话的配置文件"
}
}
}
,
{
"repo="
:
{
"#nospace"
:
true
,
"#desc"
:
{
"en"
:
"switch default repo in current session"
,
"cn"
:
"切换当前会话的默认仓库"
}
}
}
,
{
"owner="
:
{
"#nospace"
:
true
,
"#desc"
:
{
"en"
:
"switch default owner in current session"
,
"cn"
:
"切换当前会话的默认代码所有者地址"
}
}
}
]
}
}
,
"--cfg"
:
{
"#desc"
:
{
"en"
:
"manage configuration for gt"
,
"cn"
:
"gt 配置管理"
}
,
"#tip:note"
:
[
{
"en"
:
"Get Gitee access token: https://gitee.com/profile/personal_access_tokens\ndefault endpoint: https://gitee.com/api/v5\n"
,
"cn"
:
"获取 Gitee 私人令牌: https://gitee.com/profile/personal_access_tokens\n默认 endpoint (API 访问端点): https://gitee.com/api/v5\n"
}
]
,
"#tip"
:
[
{
"en"
:
"When you need to switch between the config and profile, Need to use `current` to switch\n\n`x gt --cur <config|profile>=<switch_val>`\n"
,
"cn"
:
"当你需要切换使用的 config 和 profile 时候, 需要使用 `current` 进行切换\n\n`x gt --cur <config|profile>=<switch_val>`\n"
}
]
,
"#tldr"
:
[
{
"cmd"
:
"x gt --cfg token=<token>"
,
"en"
:
"Setup Gitee access token for default initialization"
,
"cn"
:
"添加私人令牌, 进行默认初始化"
}
]
,
"set"
:
{
"#desc"
:
{
"en"
:
"Setting Gitee config"
,
"cn"
