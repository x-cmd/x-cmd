{
"#synopsis"
:
[
{
"x log init <module>"
:
null
}
,
{
"x log init1 <module>"
:
null
}
,
{
"x log init0 <module>"
:
null
}
,
{
"x log [ +module | -module | module/level ]"
:
null
}
,
{
"x log timestamp < on|off|format >"
:
null
}
]
,
"#desc"
:
{
"en"
:
"Structured logging system for shell modules with level-based filtering"
,
"cn"
:
"基于级别的结构化日志系统，用于 shell 模块"
}
,
"#tip"
:
[
{
"en"
:
"Log Levels:\n1: DEBUG - Detailed diagnostic info\n2: INFO  - General information (default)\n3: WARN  - Warning messages\n4: ERROR - Error messages\n5: NONE  - Disable all logs\n\nUse \"module:level\" for lazy evaluation (zero-cost)\nUse \"x log :module level\" for eager evaluation (accurate $?)\n"
,
"cn"
:
"日志级别：\n1: DEBUG - 详细调试信息\n2: INFO  - 一般信息（默认）\n3: WARN  - 警告信息\n4: ERROR - 错误信息\n5: NONE  - 禁用所有日志\n\n使用 \"module:level\" 惰性求值（零成本）\n使用 \"x log :module level\" 立即求值（准确 $?）\n"
}
]
,
"init"
:
{
"#desc"
:
{
"en"
:
"Initialize logger for module with all levels (debug, info, warn, error)"
,
"cn"
:
"为模块初始化完整日志（包含 debug、info、warn、error）"
}
,
"#n"
:
{
"#desc"
:
{
"en"
:
"Module name to initialize"
,
"cn"
:
"要初始化的模块名"
}
}
}
,
"init1"
:
{
"#desc"
:
{
"en"
:
"Initialize logger with debug only (minimal overhead)"
,
"cn"
:
"仅初始化 debug 级别日志（最小开销）"
}
,
"#n"
:
{
"#desc"
:
{
"en"
:
"Module name to initialize"
,
"cn"
:
"要初始化的模块名"
}
}
}
,
"init0"
:
{
"#desc"
:
{
"en"
:
"Initialize zero-cost logger (debug disabled by default)"
,
"cn"
:
"初始化零成本日志（默认禁用 debug）"
}
,
"#n"
:
{
"#desc"
:
{
"en"
:
"Module name to initialize"
,
"cn"
:
"要初始化的模块名"
}
}
}
,
"timestamp"
:
{
"#desc"
:
{
"en"
:
"Control timestamp display in logs"
,
"cn"
:
"控制日志中的时间戳显示"
}
,
"on"
:
{
"#desc"
:
{
"en"
:
"Enable timestamp with default format +%H:%M:%S"
,
"cn"
:
"启用时间戳，默认格式 +%H:%M:%S"
}
}
,
"off"
:
{
"#desc"
:
{
"en"
:
"Disable timestamp (default)"
,
"cn"
:
"禁用时间戳（默认）"
}
}
,
"#n"
:
{
"#desc"
:
{
"en"
:
"Custom timestamp format (e.g., \"+%H:%M:%S\", \"+%Y-%m-%d %H:%M:%S\")"
,
"cn"
:
"自定义时间戳格式（如 \"+%H:%M:%S\", \"+%Y-%m-%d %H:%M:%S\"）"
}
}
}
,
"default"
:
{
"#desc"
:
{
"en"
:
"Set default log level for modules"
,
"cn"
:
"设置模块的默认日志级别"
}
}
,
"run"
:
{
"#desc"
:
{
"en"
:
"Run command with specified log level"
,
"cn"
:
"以指定日志级别运行命令"
}
}
,
"exec"
:
{
"#desc"
:
{
"en"
:
"Execute command with logging"
,
"cn"
:
"执行命令并记录日志"
}
}
,
"sub"
:
{
"#desc"
:
{
"en"
:
"Hierarchical/sub log management"
,
"cn"
:
"层级/子日志管理"
}
,
"init"
:
{
"#desc"
:
{
"en"
:
"Initialize sub-log context"
,
"cn"
:
"初始化子日志上下文"
}
}
,
"fini"
:
{
"#desc"
:
{
"en"
:
"Finalize sub-log context"
,
"cn"
:
"结束子日志上下文"
}
}
,
"reset"
:
{
"#desc"
:
{
"en"
:
"Reset all sub-log state"
,
"cn"
:
"重置所有子日志状态"
}
}
}
,
"trace"
:
{
"#desc"
:
{
"en"
:
"Function tracing for debugging"
,
"cn"
:
"函数追踪调试"
}
}
,
"trace_evex"
:
{
"#desc"
:
{
"en"
:
"Trace command execution with exit code"
,
"cn"
:
"追踪命令执行及退出码"
}
}
,
"trace_time"
:
{
"#desc"
:
{
"en"
:
"Trace command execution with timing"
,
"cn"
:
"追踪命令执行及耗时"
}
}
,
"recent"
:
{
"#desc"
:
{
"en"
:
"View recent log entries"
,
"cn"
:
"查看最近的日志条目"
}
,
"#tag"
:
[
"todo"
]
}
,
