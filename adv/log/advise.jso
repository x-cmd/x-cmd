}
,
"#tag"
:
[
"inner"
]
}
,
"packrun"
:
{
"#desc"
:
{
"en"
:
"Run command and capture output to log"
,
"cn"
:
"运行命令并捕获输出到日志"
}
,
"#tag"
:
[
"todo"
]
}
,
"uirotate"
:
{
"#desc"
:
{
"en"
:
"UI rotate for interactive environments only"
,
"cn"
:
"UI 旋转（仅用于交互式环境）"
}
,
"#tag"
:
[
"inner"
]
}
,
"redirect"
:
{
"#desc"
:
{
"en"
:
"Redirect log output"
,
"cn"
:
"重定向日志输出"
}
,
"#tag"
:
[
"todo"
]
}
,
"#n"
:
{
"#exec"
:
"candidate_exec_arr=( $(ls $___X_CMD_ROOT_MOD 2>/dev/null | grep -v x-cmd | awk -v s='/' '{print $0 s}' ))"
,
"#regex"
:
{
".*/.*"
:
{
"#exec"
:
"candidate_exec_arr=( ${cur%/*}/debug ${cur%/*}/info ${cur%/*}/warn ${cur%/*}/error ${cur%/*}/none )"
}
,
"-.*"
:
{
"#exec"
:
"candidate_exec_arr=( $(ls $___X_CMD_ROOT_MOD 2>/dev/null | grep -v x-cmd | awk -v p='-' '{print p $0}'))"
}
,
"\\+.*"
:
{
"#exec"
:
"candidate_exec_arr=( $(ls $___X_CMD_ROOT_MOD 2>/dev/null | grep -v x-cmd | awk -v p='+' '{print p $0}'))"
}
}
}
,
"#tldr"
:
[
{
"cmd"
:
"x log init mymodule\nmymodule:info \"Hello World\"\nmymodule:debug \"Debug info\"\n"
,
"en"
:
"Initialize module logger and use it"
,
"cn"
:
"初始化模块日志并使用"
}
,
{
"cmd"
:
"x log mymodule/debug    # Enable debug\nx log mymodule/info     # Default level\nx log mymodule/warn     # Only warn and error\nx log mymodule/none     # Disable all\n"
,
"en"
:
"Change log level for module"
,
"cn"
:
"更改模块日志级别"
}
,
{
"cmd"
:
"x log +mymodule   # Shorthand for debug\nx log -mymodule   # Shorthand for info\n"
,
"en"
:
"Quick level switch shorthand"
,
"cn"
:
"快速切换日志级别简写"
}
,
{
"cmd"
:
"log:sub:init mymodule \"context\"\n  mymodule:info \"Step 1\"\n  mymodule:warn \"Step 2\"\nlog:sub:fini\n"
,
"en"
:
"Use hierarchical sub-logs"
,
"cn"
:
"使用层级子日志"
}
,
{
"cmd"
:
"mymodule:error -c 404 -h \"Check URL\" \"Not found\"\n"
,
"en"
:
"Error with code and help hint"
,
"cn"
:
"带错误码和帮助提示的错误日志"
}
,
{
"cmd"
:
"mymodule:info --url \"http://api.com\" --method GET \"API call\"\n"
,
"en"
:
"Structured logging with key-value pairs"
,
"cn"
:
"使用键值对的结构化日志"
}
,
{
"cmd"
:
"x:trace mymodule/function_name\n# or\nx:trace:evex command arg1 arg2\n"
,
"en"
:
"Trace function or command execution"
,
"cn"
:
"追踪函数或命令执行"
}
]
,
"#tag"
:
[
"inner"
]
}

