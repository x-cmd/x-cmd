"--raw"
:
{
"#subcmd"
:
true
,
"#desc"
:
{
"cn"
:
"发送原始的 JSON 数据"
,
"en"
:
"send raw json"
}
,
"#tldr"
:
[
{
"cmd"
:
"x telegram send raw - <<A\n  {\n      \"chat_id\": \"-790401234\",\n      \"text\": \"hello\"\n  }\n  A"
,
"cn"
:
"发送文本消息到 Telegram 群"
,
"en"
:
"Send text type messages to Telegram group"
}
]
,
