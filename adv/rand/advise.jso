{
"#name"
:
{
"rand"
:
null
,
"cn"
:
"随机数据生成器"
,
"en"
:
"Random data generator"
}
,
"#synopsis"
:
[
"x rand [subcmd] [options]"
]
,
"#desc"
:
{
"en"
:
"Generate random data including UUIDs, integers, floats, strings, email addresses, IP addresses, etc."
,
"cn"
:
"生成随机数据，包括 UUID、整数、浮点数、字符串、邮箱地址、IP 地址等"
}
,
"#tldr"
:
[
{
"cmd"
:
"x rand"
,
"cn"
:
"示例: 生成 0-32767 之间的随机整数"
,
"en"
:
"Example: Generate random integer between 0-32767"
}
,
{
"cmd"
:
"x rand int"
,
"cn"
:
"示例: 生成 0-32767 之间的随机整数"
,
"en"
:
"Example: Generate random integer between 0-32767"
}
,
{
"cmd"
:
"x rand int 1 100"
,
"cn"
:
"示例: 生成 1-100 之间的随机整数"
,
"en"
:
"Example: Generate random integer between 1-100"
}
,
{
"cmd"
:
"x rand float 0 100 4"
,
"cn"
:
"示例: 生成 0-100 之间带 4 位小数的浮点数"
,
"en"
:
"Example: Generate random float between 0-100 with 4 decimal places"
}
,
{
"cmd"
:
"x rand digit 6"
,
"cn"
:
"示例: 生成 6 位随机数字"
,
"en"
:
"Example: Generate 6 random digits"
}
,
{
"cmd"
:
"x rand uuid"
,
"cn"
:
"示例: 生成 UUID"
,
"en"
:
"Example: Generate UUID"
}
,
{
"cmd"
:
"x rand uuidv7"
,
"cn"
:
"示例: 生成 UUIDv7 格式唯一标识符"
,
"en"
:
"Example: Generate UUIDv7 format unique identifier"
}
,
{
"cmd"
:
"x rand string 16"
,
"cn"
:
"示例: 生成 16 位随机字符串"
,
"en"
:
"Example: Generate 16-character random string"
}
,
{
"cmd"
:
"x rand string 8 5"
,
"cn"
:
"示例: 生成 5 个 8 位随机字符串"
,
"en"
:
"Example: Generate 5 random 8-character strings"
}
,
{
"cmd"
:
"x rand alpha 10"
,
"cn"
:
"示例: 生成 10 位随机字母字符串"
,
"en"
:
"Example: Generate 10-character random alphabetic string"
}
,
{
"cmd"
:
"x rand alphanum 12"
,
"cn"
:
"示例: 生成 12 位随机字母数字字符串"
,
"en"
:
"Example: Generate 12-character random alphanumeric string"
}
,
{
"cmd"
:
"x rand lower 8"
,
"cn"
:
"示例: 生成 8 位随机小写字母"
,
"en"
:
"Example: Generate 8-character random lowercase letters"
}
,
{
"cmd"
:
"x rand upper 8"
,
"cn"
:
"示例: 生成 8 位随机大写字母"
,
"en"
:
"Example: Generate 8-character random uppercase letters"
}
,
{
"cmd"
:
"x rand email"
,
"cn"
:
"示例: 生成随机邮箱地址"
,
"en"
:
"Example: Generate random email address"
}
,
{
"cmd"
:
"x rand email 5"
,
"cn"
:
"示例: 生成 5 个随机邮箱地址"
,
"en"
:
"Example: Generate 5 random email addresses"
}
,
{
"cmd"
:
"x rand ip"
,
"cn"
:
"示例: 生成随机 IP 地址"
,
"en"
:
"Example: Generate random IP address"
}
,
{
"cmd"
:
"x rand ip 10"
,
"cn"
:
"示例: 生成 10 个随机 IP 地址"
,
"en"
:
"Example: Generate 10 random IP addresses"
}
]
,
"#subcmd:Identifier"
:
[
"uuid"
,
"uuidv7"
]
,
"#subcmd:Number"
:
[
"int"
,
"float"
,
"decimal"
,
"digit"
]
,
"#subcmd:String"
:
[
"string"
,
"alpha"
,
"alphanum"
,
"lower"
,
"upper"
]
,
"#subcmd:Data"
:
[
"email"
,
"ip"
]
,
"#subcmd:Other"
:
[
"--help|-h"
]
,
