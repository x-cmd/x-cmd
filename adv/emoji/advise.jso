,
"en"
:
"View emoji as an interactive app"
}
}
,
"--table"
:
{
"#desc"
:
{
"cn"
:
"以静态表格的格式列出 emoji"
,
"en"
:
"List emoji in a static table format"
}
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"提供一个group"
,
"en"
:
"Provide a group"
}
,
"#exec"
:
"___x_cmd_emoji___advise_ls_all_group"
}
,
"#2"
:
{
"#desc"
:
{
"cn"
:
"提供一个subgroup"
,
"en"
:
"Provide a subgroup"
}
,
"#exec"
:
