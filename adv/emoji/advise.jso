:
{
"cn"
:
"提供一个group"
,
"en"
:
"Provide a group"
}
,
"#exec"
:
"___x_cmd_emoji___advise_ls_all_group"
}
}
,
"--csv"
:
{
"#desc"
:
{
"cn"
:
"以 CSV 格式列出 emoji"
,
"en"
:
"List emoji in CSV format"
}
}
,
"--app"
:
{
"#desc"
:
{
"cn"
:
