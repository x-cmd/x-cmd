{
"#name"
:
{
"emoji"
:
null
,
"en"
:
"List emojis"
,
"cn"
:
"罗列 emoji"
}
,
"#tldr"
:
[
{
"cmd"
:
"x emoji"
,
"cn"
:
"示例: 以交互式 app 查看所有表情符号"
,
"en"
:
"Example: View all emojis in interactive app"
}
,
{
"cmd"
:
"x emoji ls"
,
"cn"
:
"示例: 列出所有表情符号"
,
"en"
:
"Example: List all emojis"
}
,
{
"cmd"
:
"x emoji ls smileys face-smiling"
,
"cn"
:
"示例: 列出 smileys/face-smiling 组的表情"
,
"en"
:
"Example: List emojis in smileys/face-smiling group"
}
,
{
"cmd"
:
"x emoji ls smileys --csv"
,
"cn"
:
"示例: 以 CSV 格式列出 smileys 组表情"
,
"en"
:
"Example: List smileys group emojis in CSV format"
}
,
{
"cmd"
:
"x emoji ls --table"
,
"cn"
:
"示例: 以表格形式列出表情符号"
,
"en"
:
"Example: List emojis in table format"
}
,
{
"cmd"
:
"x emoji ls --group"
,
"cn"
:
"示例: 列出所有表情符号分组"
,
"en"
:
"Example: List all emoji groups"
}
,
{
"cmd"
:
"x emoji update"
,
"cn"
:
"示例: 更新本地 emoji 资源包"
,
"en"
:
"Example: Update local emoji resource package"
}
,
{
"cmd"
:
"x emoji which"
,
"cn"
:
"示例: 查看 emoji 资源包缓存路径"
,
"en"
:
"Example: View emoji resource cache path"
}
]
,
"#subcmd:Query"
:
[
"ls"
,
"which"
]
,
"#subcmd:Management"
:
[
"update"
]
,
"#subcmd:Other"
:
[
"tohex"
,
"--help|-h"
]
,
"ls"
:
{
"#desc"
:
{
"cn"
:
"列出emoji"
,
"en"
:
"Display emoji"
}
,
"--all"
:
{
"#desc"
:
{
"cn"
:
"列出所有的 emoji"
,
"en"
:
"List all emoji"
}
}
,
"--group"
:
{
