{
"#name"
:
{
"slash"
:
null
,
"cn"
:
"Agent Slash Command 管理器"
,
"en"
:
"Agent Slash Command Manager"
}
,
"#desc"
:
{
"cn"
:
"自动扫描多个 Agent 工具目录的命令和技能，注册为 shell 可直接运行的 /command。\n扫描目录: .claude, .agents, .codex, .config/opencode, .openclaw\n支持 commands/*.md 和 skills/*/SKILL.md 两种格式。\n通过 x agent request 执行，不限于特定 Agent 平台。\n"
,
"en"
:
"Auto-scan commands and skills from multiple agent tool directories, register as shell-runnable /command.\nScanned dirs: .claude, .agents, .codex, .config/opencode, .openclaw\nSupports both commands/*.md and skills/*/SKILL.md formats.\nExecutes via x agent request, not limited to a specific agent platform.\n"
}
,
"#subcmd:core"
:
[
"ls"
,
"run"
,
"get"
]
,
"#subcmd:system"
:
[
"init"
,
"compile"
,
"check"
,
"cat"
]
,
"init"
:
{
"#desc"
:
{
"cn"
:
"扫描所有 Agent 工具目录并注册 slash command"
,
"en"
:
"Scan all agent tool directories and register slash commands"
}
,
"#tldr"
:
[
{
"cmd"
:
"x slash init"
,
"cn"
:
"初始化当前项目的 slash command"
,
"en"
:
"Initialize slash commands for current project"
}
]
}
,
"ls"
:
{
"#desc"
:
{
"cn"
:
"列出所有已注册的 slash command"
,
"en"
:
"List all registered slash commands"
}
,
"--tsv"
:
{
"#desc"
:
{
"cn"
:
"以 TSV 格式输出"
,
"en"
:
"Output in TSV format"
}
}
,
"--app"
:
{
"#desc"
:
{
"cn"
:
"使用交互式应用界面"
,
"en"
:
"Use interactive app interface"
}
}
,
"--word"
:
{
"#desc"
:
{
"cn"
:
"只输出命令名称"
,
"en"
:
"Output only command names"
}
}
,
"#tldr"
:
[
{
"cmd"
:
"x slash ls"
,
"cn"
:
"列出所有 slash command"
,
"en"
:
"List all slash commands"
}
,
{
"cmd"
:
"x slash ls --tsv"
,
"cn"
:
"以 TSV 格式输出"
,
"en"
:
"Output in TSV format"
}
,
{
"cmd"
:
"x slash ls --word"
,
"cn"
:
"只输出命令名称"
,
"en"
:
"Output only command names"
}
]
}
,
"compile"
:
{
"#desc"
:
{
"cn"
:
"编译生成 shell 函数代码"
,
"en"
:
"Compile shell function code"
}
,
"#tldr"
:
[
{
"cmd"
:
"x slash compile"
,
"cn"
:
"重新编译 shell 函数"
,
"en"
:
"Recompile shell functions"
}
]
}
,
"cat"
:
{
"#desc"
:
{
"cn"
:
"查看当前配置文件内容"
,
"en"
:
"View current configuration file content"
}
}
,
"check"
:
{
"#desc"
:
{
"cn"
:
"检查并自动恢复配置"
,
"en"
:
"Check and auto-restore configuration"
}
}
,
"get"
:
{
"#desc"
:
{
"cn"
:
"获取指定 slash command 的配置"
,
"en"
:
"Get configuration for specified slash command"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"slash command 名称"
,
"en"
:
"Slash command name"
}
,
"#exec"
:
"___x_cmd_slash_ls_word"
}
}
,
"run"
:
{
"#desc"
:
{
"cn"
:
"通过 x agent request 运行指定的 slash command"
,
"en"
:
"Run the specified slash command via x agent request"
}
,
"#1"
:
{
"#desc"
:
{
"cn"
:
"slash command 名称"
,
"en"
:
"Slash command name"
}
,
"#exec"
:
"___x_cmd_slash_ls_word"
}
,
"--info"
:
{
"#desc"
:
{
"cn"
:
"显示 slash command 的元信息，不执行命令"
,
"en"
:
"Show slash command metadata without executing"
}
}
,
"--cat"
:
{
"#desc"
:
{
"cn"
:
"显示 slash command 的完整内容，不执行命令"
,
"en"
:
"Show slash command full content without executing"
}
}
,
"--debug"
:
{
"#desc"
:
{
"cn"
:
"启用调试模式，实时输出 JSON 解析和事件日志"
,
"en"
:
"Enable debug mode, output real-time JSON parsing and event logs"
}
}
,
"--quick"
:
{
"#desc"
:
{
"cn"
:
"尽可能快，减少思考过程"
,
"en"
:
"As fast as possible, reduce the thinking process"
}
}
,
"#tldr"
:
[
{
"cmd"
:
"x slash run review-pr"
,
"cn"
:
"示例: 运行 review-pr 命令"
,
"en"
:
"Example: run the review-pr command"
}
,
{
"cmd"
:
"/review-pr"
,
"cn"
:
"示例: 直接通过 / 前缀运行"
,
"en"
:
"Example: run directly with / prefix"
}
,
{
"cmd"
:
"/review-pr --info"
,
"cn"
:
"示例: 查看 review-pr 的元信息"
,
"en"
:
"Example: show review-pr metadata"
}
,
{
"cmd"
:
"/review-pr --cat"
,
"cn"
:
"示例: 查看 review-pr 的完整内容"
,
"en"
:
"Example: show review-pr full content"
}
]
}
,
"#tldr"
:
[
{
"cmd"
:
"x slash init"
,
"cn"
:
"扫描所有 Agent 目录并注册 slash command"
,
"en"
:
"Scan all agent directories and register slash commands"
}
,
{
"cmd"
:
"x slash ls"
,
"cn"
:
"列出所有已注册的 slash command"
,
"en"
:
"List all registered slash commands"
}
,
{
"cmd"
:
"x slash run my-skill"
,
"cn"
:
"示例: 通过 x agent request 运行 slash command"
,
"en"
:
"Example: run slash command via x agent request"
}
,
{
"cmd"
:
"/my-skill"
,
"cn"
:
"示例: 直接运行已注册的 slash command"
,
"en"
:
"Example: run a registered slash command directly"
}
,
{
"cmd"
:
"/my-skill --info"
,
"cn"
:
"示例: 查看已注册命令的元信息"
,
"en"
:
"Example: show metadata of a registered slash command"
}
]
,
"#subcmd_help_tip"
:
true
,
"#other"
:
{
"en"
:
{
"Please visit our homepage for more information:"
:
"https://x-cmd.com/mod/slash"
}
,
