# shellcheck shell=dash

___X_CMD_CLAUDE_TENCENT_DEFAULT_ENDPOINT="https://api.lkeap.cloud.tencent.com/coding/anthropic"
___X_CMD_CLAUDE_TENCENT_DEFAULT_FIRST_MODEL="tc-code-latest"

___x_cmd_claude_tencent(){
    local op="$1"
    case "$op" in
        -h|--help)      ___x_cmd help -m claude tencent; return 0 ;;
        --cfg)          shift;
                        ___x_cmd_claude_tencent_cfg "$@"; return $? ;;
        --)             shift ;;
    esac

    local model=""
    local apikey=""
    local endpoint=""
    local x_=""

    claude:provider:fetch:init
    ___x_cmd_claude_tencent___fetch_   || return $?

    ANTHROPIC_API_KEY="" API_TIMEOUT_MS="$x_timeout"        \
        ___x_cmd_claude_other___use     tencent              \
        "$x_url" "$x_apikey" "$x_model" "$x_fastmodel" "$x_nonessential_traffic" "$x_effortlevel" "$@"
}

___x_cmd_claude_tencent___fetch_(){
    local model=""
    local apikey=""
    local endpoint=

    ___x_cmd_claude_tencent_cur model:=    apikey:=    endpoint:= 2>/dev/null

    [ -n "$apikey" ] || {
        claude:warn \
            --tip1 'x claude tencent --cfg'                           \
            --tip2 'x claude tencent --cfg apikey=<YOUR-API-KEY>'     \
            "Please setup tencent coding plan API-KEY."
        return 1
    }

    [ -n "$endpoint" ] || endpoint="$___X_CMD_CLAUDE_TENCENT_DEFAULT_ENDPOINT"

    x_url="$endpoint"
    x_apikey="$apikey"

    x_model="${model}"
    [ -n "$x_model" ] || x_model="$___X_CMD_CLAUDE_TENCENT_DEFAULT_FIRST_MODEL"

    x_fastmodel="${x_model}"
    x_effortlevel=auto
}


xrc cfgy
___x_cmd_claude_tencent_cfg(){
    [ "$#" -gt 0 ] || {
        ___x_cmd_claude_tencent_init
        return
    }

    local op="$1"; shift
    case "$op" in
        -h|--help)      ___x_cmd help -m claude tencent --cfg ;;
        *)              ___x_cmd_claude_tencent_cfg___invoke "$op" "$@" ;;
    esac
}


___x_cmd_claude_tencent_cur(){
    local X_help_cmd=; X_help_cmd='___x_cmd help -m claude tencent --cur' help:arg:parse
    ___x_cmd_claude_tencent_cfg --current "$@"
}

___x_cmd_claude_tencent_init(){
    local cur_apikey=; local cur_model=; local cur_endpoint

    if [ -f "$(___x_cmd_claude_tencent_cur --get config)" ]; then
        ___x_cmd_claude_tencent_cur cur_apikey:=apikey cur_model:=model cur_endpoint:=endpoint 2>/dev/null
    fi

    claude:info "To get tencent coding plan API key -> https://hunyuan.cloud.tencent.com/#/app/subscription"

    ___x_cmd_claude_tencent_cfg___invoke --init ${cur_apikey:+"--ctrl_exit_strategy"} \
        apikey      "Set up the tencent coding plan API key"                     \
                    "$cur_apikey"   '=~*' "^[A-Za-z0-9_-]+$" --                  \
        model       "Set up the tencent API model"                               \
                    "${cur_model:-"$___X_CMD_CLAUDE_TENCENT_DEFAULT_FIRST_MODEL"}" '=' tc-code-latest hunyuan-2.0-instruct hunyuan-2.0-thinking hunyuan-t1 hunyuan-turbos minimax-m2.5 kimi-k2.5 glm-5  --  \
        endpoint    "Set up the endpoint (optional)"                            \
                    "${cur_endpoint:-"$___X_CMD_CLAUDE_TENCENT_DEFAULT_ENDPOINT"}" || return $?
}


___X_CMD_CLAUDE_TENCENT_CFG_VARLIST="apikey,model,endpoint"
___x_cmd_claude_tencent_cfg___invoke(){
    ___x_cmd_cfgy_obj   \
        --prefix            ___X_CMD_CLAUDE_TENCENT_CFG_DATA                \
        --default-config    "${___X_CMD_ROOT_CFG}/claude/tencent/X.cfg.yml" \
        --current-config    "${___X_CMD_CLAUDE_TENCENT_LOCAL_CONFIG}"       \
        --current-profile   "${___X_CMD_CLAUDE_TENCENT_LOCAL_PROFILE}"      \
        --varlist           "$___X_CMD_CLAUDE_TENCENT_CFG_VARLIST"          \
        "$@"
}


