___x_cmd_hub_cfgb_ls(){
    local mod
    printf "x-cmd:\n"
    while read -r mod; do
        [ -n "$mod" ] || continue
        printf "  - %s\n" "$mod"
    done <<A
$___X_CMD_HUB_CFGB_MOD
A


    local homecfg
    printf "home:\n"
    while read -r homecfg; do
        [ -n "$homecfg" ] || continue
        printf "  - %s\n" "$homecfg"
    done <<A
$___X_CMD_HUB_CFGB_USERCONFIG
A
}
