# shellcheck shell=dash

# Reference:      https://core.telegram.org/bots/api#sendmessage
___x_cmd_telegram_bot_send() {
    param:subcmd ___x_cmd_telegram_bot_send    \
        --text            "send text"            \
        --file            "send file"            \
        --poll            "send Poll"            \
        --contact         "send Contact"         \
        --dice            "send Dice"            \
        --venue           "send Venue"           \
        --location        "send Location"        \
        --raw             "send raw json"        \
        --stop_poll       "send stopPoll"        \
        --image           "send image"           \
        --video           "send Video"           \
        --video_note      "send VideoNote"       \
        --audio           "send Audio"           \
        --voice           "send Voice"           \
        --animation       "send Animation"       \

    param:subcmd:try
    param:run

    if [ "$#" -eq 0 ]; then
        ___x_cmd_telegram bot send --help
    else
        ___x_cmd_telegram_bot_send_text "$@"
    fi
    return
}

___x_cmd_telegram_bot___save_sent_() {
    local chatid="$1"
    local msg_type="$2"
    local source_content="$3"

    local x_; ___x_cmd date timestamp_
    local send_time="$x_"

    local record_content="$source_content"
    if [ -n "$source_content" ] && [ -f "$source_content" ]; then
        local asset_dir="$___X_CMD_TELEGRAM_BOT_PATH/sent/asset"
        ___x_cmd mkdirp "$asset_dir"
        local target_path="${asset_dir}/${send_time}_${source_content##*/}"

        ___x_cmd_cmds cp "$source_content" "$target_path" || {
            telegram:warn "Failed to copy file to $target_path"
        }
        record_content="$target_path"
    fi

    local sent_data_path="$___X_CMD_TELEGRAM_BOT_PATH/sent/data_${chatid}.tsv"
    ___x_cmd ensurefp "$sent_data_path"
    printf '%s\t%s\t%s\n' "$send_time" "$msg_type" "$record_content" >> "$sent_data_path" || {
        telegram:warn "Failed to save sent info to $sent_data_path"
    }
}

___x_cmd_telegram_bot_send_text() {
    param:scope     telegram
    param:dsl <<A
option:
    #1          "Provide text"          <>=""
    --chatid      "Provide chat id"       <>=""
    --token     "token"                 <>=""
    --pipe|-p   "pipe"
    --fp        "save sent message to data file"
A
    param:run

    local text
    local msg_type="sendMessage"

    if [ -n "$pipe" ]; then
        text="$(___x_cmd_cmds_cat)"
    else
        text="$1"
    fi

    local x_; ___x_cmd_telegram_bot___get_chat_ || return 1
    local chatid="$x_"

    local resp; resp="$(___x_cmd_telegram_bot___send_json <<A
{
    "chat_id": "$chatid",
    "text": "$text"
}
A
)"

    local status
    ___x_cmd jo env . status=.ok <<A
$resp
A

    if [ "$status" = "true" ] && [ -n "$fp" ]; then
        ___x_cmd_telegram_bot___save_sent_ "$chatid" "text" "$text"
    fi

    printf "%s" "$resp"
}

