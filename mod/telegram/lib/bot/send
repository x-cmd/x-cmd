A
    param:run
    local msg_type=sendPoll
    local x_; ___x_cmd_telegram_bot___get_chat_ || return 1
    local chatid="$x_"

    options=$(___x_cmd_telegram_bot___get_mobiles "${options}")
    local resp; resp="$(___x_cmd_telegram_bot___send_json <<A
{
    "chat_id": "$chatid",
    "question" : "$question",
    "options" : [ $options ]
}
A
)"

    local status
    ___x_cmd jo env . status=.ok <<A
