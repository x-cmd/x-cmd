# shellcheck shell=dash

___x_cmd_clawhub_account_logout(){
    case "$1" in -h|--help) shift; ___x_cmd help -m clawhub account logout "$@" ; return 0 ;; esac

    {
        ___x_cmd_clawhub_cfg --unset token
    } || {
        ___x_cmd_ui_tf false "Failed to unset token" >&2
        return 1
    }
    ___x_cmd_ui_tf true "Logout Successfully"
}
