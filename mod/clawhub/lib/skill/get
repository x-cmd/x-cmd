# POST /api/v1/skills/{slug}/merge
___x_cmd_clawhub_skill_merge(){
    local X_help_cmd='___x_cmd_clawhub___help skill merge'
    help:arg:parse

    local slug="$1";        [ -n "$slug" ]        || M='Provide target skill slug' N=clawhub log:ret:64
    local source_slug="$2"; [ -n "$source_slug" ] || M='Provide source skill slug' N=clawhub log:ret:64
    shift 2

    local resp=
    resp="$(___x_cmd_clawhub_u_curl post "/api/v1/skills/$(___x_cmd url encode "$slug")/merge" -- "source=$source_slug")" || {
        ___x_cmd_clawhub_u_handle_resp false "Failed to merge '$source_slug' into '$slug':"
        return 1
    }
    ___x_cmd_clawhub_u_handle_resp true "Merged '$source_slug' into '$slug'"
}
