# shellcheck shell=dash

xrc:mod:lib clawhub              \
            skill/search          \
            skill/get             \
            skill/versions        \
            skill/scan            \
            skill/file            \
            skill/resolve         \
            skill/download        \
            skill/publish         \
            skill/transfer        \
            skill/moderate

___x_cmd_clawhub_skill(){
    case "$1" in -h|--help) shift; ___x_cmd help -m clawhub skill "$@" ; return 0 ;; esac

    local op="$1"
    case "$op" in
        search|ls|get|versions|version|scan|file|resolve|download|publish|delete|undelete|rename|merge|moderate) shift
            "___x_cmd_clawhub_skill_$op" "$@"                         ;;
        transfer) shift
            ___x_cmd_clawhub_skill_transfer "$@" ;;
        "") ___x_cmd_clawhub_u_subcmd_invalid skill "" ;;
        *) ___x_cmd_clawhub_u_subcmd_invalid skill "$@" ;;
    esac
}
