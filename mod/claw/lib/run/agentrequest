# shellcheck shell=dash

___x_cmd_claw_agentrequest(){
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --help|-h)              ___x_cmd help -m claw agentrequest; return 0 ;;
            *)                      break ;;
        esac
    done

    if [ -z "$___X_CMD_CLAW_AGENT_REFERENCE_WS" ]; then
        ___X_CMD_CLAW_AGENT_REFERENCE_WS="$HOME/.openclaw/workspace"
    fi

    local im="$1";      [ -n "$im" ] || N=claw M="Please provide IM platform name (e.g., weixin|telegram)" log:ret:64
    local chatid="$2";  [ -n "$chatid" ] || N=claw M="Please provide chatid" log:ret:64

    ___x_cmd_claw_run___ensure "$im" || return $?
    ___x_cmd_claw_run___agentrequest___handlemsg "$@"
}

___x_cmd_claw_run___agentrequest___handlemsg(){
    local im="$1";      [ -n "$im" ] || N=claw M="Please provide IM platform name (e.g., weixin|telegram)" log:ret:64
    local chatid="$2";  [ -n "$chatid" ] || N=claw M="Please provide chatid" log:ret:64
    local msg="$3";     [ -n "$msg" ] || N=claw M="Please provide message" log:ret:64

    if [ -n "$___X_CMD_CLAW_BOT_RECENT_STDOUT_LOG_DIR" ]; then
        local logfp="$___X_CMD_CLAW_BOT_RECENT_STDOUT_LOG_DIR/${im}-${chatid}.log"
        ___x_cmd ensurefp "$logfp"
        exec >>"$logfp" 2>&1
    fi

    ___x_cmd_claw_run___agentrequest___checkunavailable || return 0

    ___x_cmd rmrf "$___X_CMD_CLAW_BOT_WS/HEARTBEAT_OK"
    ___x_cmd ensurefp "$___X_CMD_CLAW_BOT_HEARTBEAT/idle_count"
    printf "%s\n" "0" > "$___X_CMD_CLAW_BOT_HEARTBEAT/idle_count"

    local workspace_dir="$___X_CMD_CLAW_BOT_WS/${im}-${chatid}"
    local exitcode=0

    # Initialize workspace from template if first run
    if [ ! -d "$workspace_dir" ]; then
        first_contact_prompt="$(___x_cmd_cmds cat "$___X_CMD_ROOT_MOD/claw/lib/data/prompt/first_contact.md" 2>/dev/null)"
        ___x_cmd cp -r "$___X_CMD_ROOT_MOD/claw/lib/data/workspace/msg" "$workspace_dir"
        ___x_cmd mkdirp "$workspace_dir/memory"
        ___x_cmd mkdirp "$workspace_dir/tmp"
    else
        # Ensure missing template files are present without overwriting existing ones
        local i; for i in "$___X_CMD_ROOT_MOD/claw/lib/data/workspace/msg"/*; do
            [ -e "$i" ] || continue
            target="$workspace_dir/${i##*/}"
            [ -e "$target" ] || ___x_cmd cp -r "$i" "$target"
        done
        ___x_cmd mkdirp "$workspace_dir/memory"
        ___x_cmd mkdirp "$workspace_dir/tmp"
    fi

    if [ "$workspace_dir/AGENTS.md" -ot "$___X_CMD_ROOT_METADATA/version_sum" ]; then
        claw:info "Workspace template may have been updated, checking if structure optimization is needed"
        ___x_cmd_cmds touch "$workspace_dir/AGENTS.md"
