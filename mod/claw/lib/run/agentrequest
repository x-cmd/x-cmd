___x_cmd_claw_run___agentrequest___handleheartbeat(){
    local im="$1"
    local chatid="$2"

    if [ -z "$im" ] || [ -z "$chatid" ]; then
        return 0
    fi

    ___x_cmd_claw_run___agentrequest___checkunavailable || return 0

    local active_chat_line=""
    local reply_text_hint=""
    case "$im" in
        weixin)
            active_chat_line="ACTIVE CHAT: weixin"
            reply_text_hint="  * For text:                 x weixin send --text <msg>" ;;
        *)
            active_chat_line="ACTIVE CHAT: $im (chatid: \"$chatid\")"
            reply_text_hint="  * For text:                 x $im send --text --chat \"$chatid\" <msg>" ;;
    esac

    ___x_cmd agent request \
        --workspace "$___X_CMD_CLAW_BOT_WS"    \
        --reference-workspace "$___X_CMD_CLAW_AGENT_REFERENCE_WS" \
        "You are X-CLAW, running a periodic heartbeat task. Current time: $(___x_cmd date iso).

$active_chat_line
- Reply using:                x $im send -h
$reply_text_hint
- Your workspace:             \"$___X_CMD_CLAW_BOT_WS\"
- Chat memory reference:      \"$___X_CMD_CLAW_BOT_WS/$im-$chatid\"

YOUR TASKS:
1. RETRIEVE: Search and review the chat memory reference and your own workspace for context, unresolved questions, or pending actions.
2. EXPLORE: Look for useful information, system state changes, or opportunities to assist.
3. SUMMARIZE: Distill what you found into key points.
4. CORRECT: Identify any recurring mistakes, gaps, or outdated assumptions in your memory or behavior; update your notes accordingly.
5. PLAN: Formulate a concise next-step plan if there are deferred tasks or follow-ups.
PROACTIVE ENGAGEMENT (STRICT — default is **SILENCE**):
- DO NOT send \"I'm online\", \"heartbeat received\", \"system nominal\", \"standing by\", \"beep boop\", or ANY status-confirmation message. These are pure noise to the user.
- ONLY send a message if you have SUBSTANTIVE, TIME-SENSITIVE, or USER-REQUESTED information: e.g., an answer to a previously asked question, an important reminder the user explicitly set, a critical alert, or a follow-up that directly advances a deferred task.
- If there is nothing genuinely worth the user's attention, STAY SILENT.

NO-OP MARKER:
If after completing ALL tasks above you determine there is truly NOTHING more to do — no pending tasks, no memory to update, no proactive message to send, no corrections needed — create the marker file by running:
  touch \"$___X_CMD_CLAW_BOT_HEARTBEAT/heartbeat_done\"
This signals that you are completely idle and prevents unnecessary future heartbeat agent requests until new activity (message or cron task) occurs. Only create this file when you are certain there is absolutely nothing left to act upon.

RULES:
- Do NOT write to stdout. All your findings, summaries, corrections, and plans must be persisted into memory files under \"$___X_CMD_CLAW_BOT_WS\" (e.g., a heartbeat log or notes file).
- Keep your output concise.
- Do not spawn unnecessary long-running background tasks.
" || {
        ___x_cmd_claw_run___agentrequest___markunavailable
        return 1
    }
}

___x_cmd_claw_run___agentrequest___checkunavailable(){
    local agent_unavailable_file="$___X_CMD_CLAW_BOT_HEARTBEAT/agent_unavailable"
    [ -f "$agent_unavailable_file" ] || return 0

    local fail_count=0 fail_ts=0
    read -r fail_count fail_ts < "$agent_unavailable_file"

    local cooldown
    case "$fail_count" in
        1) cooldown=120 ;;
        2) cooldown=240 ;;
        3) cooldown=480 ;;
        4) cooldown=960 ;;
        5) cooldown=1920 ;;
        *) cooldown=3600 ;;
    esac

    local x_
    ___x_cmd date timestamp_
    if [ "$(( x_ - fail_ts ))" -lt "$cooldown" ]; then
        return 1
    fi

    ___x_cmd rmrf "$agent_unavailable_file"
    return 0
}

___x_cmd_claw_run___agentrequest___markunavailable(){
    local agent_unavailable_file="$___X_CMD_CLAW_BOT_HEARTBEAT/agent_unavailable"
    local fail_count=1; local _=""
    [ ! -f "$agent_unavailable_file" ] || read -r fail_count _ < "$agent_unavailable_file"
    fail_count=$(( fail_count + 1 ))

    local x_
    ___x_cmd date timestamp_
    ___x_cmd ensurefp "$agent_unavailable_file"
    printf "%s %s\n" "$fail_count" "$x_" > "$agent_unavailable_file"
}
