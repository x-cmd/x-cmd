Reference template: $___X_CMD_ROOT_MOD/claw/lib/data/workspace/msg/
Current workspace:  $workspace_dir

Guidelines:
- This is a reference only — you decide what to adopt
- Compare structures and selectively apply beneficial changes
- Preserve existing user content and customizations
- Focus on structural gaps or organizational improvements
</workspace_check>"
    fi

    local latest_msg
    case "$im" in
        weixin)
            latest_msg="$(___x_cmd claw weixin recent-msg 2>/dev/null)" || {
                claw:debug "Failed to fetch recent message for weixin"
                latest_msg="[unavailable]"
            } ;;
        *)
