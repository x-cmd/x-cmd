___x_cmd_claw_run___agentrequest___handleheartbeat(){
    if [ -n "$___X_CMD_CLAW_BOT_RECENT_STDOUT_LOG_DIR" ]; then
        local logfp="$___X_CMD_CLAW_BOT_RECENT_STDOUT_LOG_DIR/heartbeat.log"
        ___x_cmd ensurefp "$logfp"
        exec >>"$logfp" 2>&1
    fi

    ___x_cmd_claw_run___agentrequest___checkunavailable || return 0

    local imdir="$___X_CMD_CLAW_BOT_HEARTBEAT/im_activity"
    [ -d "$imdir" ] || {
        claw:warn "[HB] No IM activity directory found. Skipping heartbeat."
        return 0
    }

    local active_platforms=""
    local reply_methods=""
    local default_reply_im=""
    local default_reply_chatid=""
    local max_ts=0
    local im_count=0

    local i active_im active_chatid active_ts x_
    for i in "$imdir"/*; do
        [ -f "$i" ] || continue
        active_im="${i##*/}"
        read -r active_chatid active_ts < "$i"
        [ -n "$active_chatid" ] || continue
        [ -n "$active_ts" ] || continue

        im_count=$((im_count + 1))

        x_=""; ___x_cmd epoch minus_ -H "$active_ts"
        active_platforms="$active_platforms
  - $active_im (chatid: $active_chatid, last_active: $x_)"

        # Build reply method hints for this platform
        case "$active_im" in
            weixin)
                reply_methods="$reply_methods
  * weixin:   x weixin send --text '<msg>'" ;;
            telegram)
                reply_methods="$reply_methods
  * telegram: x telegram send --text --chatid \"$active_chatid\" '<msg>'" ;;
            feishu)
                reply_methods="$reply_methods
  * feishu:   x feishu abot send --text --chatid \"$active_chatid\" '<msg>'" ;;
            qywx)
                reply_methods="$reply_methods
  * qywx:     x qywx abot send --text --chatid \"$active_chatid\" '<msg>'" ;;
            *)
                reply_methods="$reply_methods
  * $active_im: x $active_im send --text --chat \"$active_chatid\" '<msg>'" ;;
        esac

        # Find the most recently active platform
        if [ "$active_ts" -gt "$max_ts" ]; then
            max_ts="$active_ts"
            default_reply_im="$active_im"
            default_reply_chatid="$active_chatid"
        fi
    done

    [ "$im_count" -gt 0 ] || {
        claw:warn "[HB] No active platforms found. Skipping heartbeat."
        return 0
    }

    local workspace_dir="$___X_CMD_CLAW_BOT_WS"

    claw:info "[HB] Processing global heartbeat for $im_count platform(s), default reply to $default_reply_im"

    ___x_cmd agent request \
        --timeout 1800 \
        --workspace "$workspace_dir"  \
        --reference-workspace "$___X_CMD_CLAW_AGENT_REFERENCE_WS" \
        "You are X-CLAW, running a periodic heartbeat task. Current time: '$(___x_cmd date iso)'.

ACTIVE PLATFORMS:$active_platforms

DEFAULT REPLY TARGET: $default_reply_im (most recent)

REPLY METHODS:$reply_methods
- Your workspace:             \"$workspace_dir\"

ROUTING RULES:
- Default: reply to the most recently active platform ($default_reply_im)
- You may reply to ANY platform using the methods above
- Do NOT broadcast the same message to all platforms unless the information is critical for ALL
- If nothing worth the user's attention, STAY SILENT

YOUR TASKS:
1. RETRIEVE: Search and review your workspace for context, unresolved questions, or pending actions.
2. EXPLORE: Look for useful information, system state changes, or opportunities to assist.
3. SUMMARIZE: Distill what you found into key points.
4. CORRECT: Identify any recurring mistakes, gaps, or outdated assumptions in your memory or behavior; update your notes accordingly.
5. PLAN: Formulate a concise next-step plan if there are deferred tasks or follow-ups.

PROACTIVE ENGAGEMENT (STRICT — DEFAULT IS **SILENCE**):
- DO NOT send \"I'm online\", \"heartbeat received\", \"system nominal\", \"standing by\", or ANY status-confirmation message.
- DO NOT greet the user. DO NOT use small talk (\"Good morning\", \"How are you\", \"Hope you're doing well\", etc.).
- DO NOT apologize for being silent or explain why you have nothing to say.
- ONLY send a message if you have SUBSTANTIVE, TIME-SENSITIVE, or USER-REQUESTED information.
- If there is nothing genuinely worth the user's attention, STAY SILENT.

NO-OP MARKER:
If after completing ALL tasks above you determine there is truly NOTHING more to do — no pending tasks, no memory to update, no proactive message to send — create the marker file by running:
  touch \"$___X_CMD_CLAW_BOT_HEARTBEAT/heartbeat_done\"
This prevents unnecessary future heartbeat agent requests until new activity occurs.

RULES:
- Do NOT write to stdout. All findings must be persisted into memory files under \"$___X_CMD_CLAW_BOT_WS\".
- Keep your output concise.
- Do not spawn unnecessary long-running background tasks.
" || {
        ___x_cmd_claw_run___agentrequest___markunavailable
        return 1
    }
}

___x_cmd_claw_run___agentrequest___checkunavailable(){
    local agent_unavailable_file="$___X_CMD_CLAW_BOT_HEARTBEAT/agent_unavailable"
    [ -f "$agent_unavailable_file" ] || return 0

    local fail_count=0 fail_ts=0
    read -r fail_count fail_ts < "$agent_unavailable_file"

    local cooldown
    case "$fail_count" in
        1) cooldown=120 ;;
        2) cooldown=240 ;;
        3) cooldown=480 ;;
        4) cooldown=960 ;;
        5) cooldown=1920 ;;
        *) cooldown=3600 ;;
    esac

    local x_
    ___x_cmd date timestamp_
    local elapsed=$(( x_ - fail_ts ))
    if [ "$elapsed" -lt "$cooldown" ]; then
        local remaining=$(( cooldown - elapsed ))
        claw:info "Agent unavailable (fail_count=$fail_count), ${remaining}s cooldown remaining — skipping request"
        return 1
    fi

    claw:info "Agent cooldown expired (fail_count=$fail_count, cooldown=${cooldown}s) — availability restored"
    ___x_cmd rmrf "$agent_unavailable_file"
    return 0
}

___x_cmd_claw_run___agentrequest___markunavailable(){
    local agent_unavailable_file="$___X_CMD_CLAW_BOT_HEARTBEAT/agent_unavailable"
    local fail_count=1; local _=""
    [ ! -f "$agent_unavailable_file" ] || read -r fail_count _ < "$agent_unavailable_file"
    fail_count=$(( fail_count + 1 ))

    local x_
    ___x_cmd date timestamp_
    ___x_cmd ensurefp "$agent_unavailable_file"
    printf "%s %s\n" "$fail_count" "$x_" > "$agent_unavailable_file"
    claw:error "Agent marked unavailable (fail_count=$fail_count) — cooldown starts"
}
