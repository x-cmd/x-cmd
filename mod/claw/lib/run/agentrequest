    local agents_file="AGENTS.md"
    case "$harness" in
        claude*)    agents_file="CLAUDE.md" ;;
    esac

    # Ensure workspace directory exists and sync missing template files
    if [ ! -d "$workspace_dir" ]; then
        first_contact_prompt="$(___x_cmd_cmds cat "$___X_CMD_ROOT_MOD/claw/lib/data/prompt/first_contact.md" 2>/dev/null)"
    fi
    ___x_cmd_claw_run_workspace_ensure "$workspace_dir" "$___X_CMD_ROOT_MOD/claw/lib/data/workspace/msg" "$harness"
    ___x_cmd mkdirp "$workspace_dir/memory"
    ___x_cmd mkdirp "$workspace_dir/tmp"

    x_=""; ___x_cmd_claw_run_workspace_check_prompt_ "$workspace_dir" "$___X_CMD_ROOT_MOD/claw/lib/data/workspace/msg" "$harness"
