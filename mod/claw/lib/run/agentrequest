<variables>
<variable name='AGENTS_FILE'>${agents_file}
</variable>
<variable name='FIRST_CONTACT_PROMPT'>${first_contact_prompt}
</variable>
<variable name='CHATID'>${chatid}
</variable>
<variable name='WORKSPACE_DIR'>${workspace_dir}
</variable>
<variable name='CURRENT_TIME'>$(___x_cmd date iso)
</variable>
<variable name='CHECK_PROMPT'>${check_prompt}
</variable>
<variable name='MSG'>${msg}
</variable>
</variables>"
            ___x_cmd agent request  \
                --timeout 1800 \
                --debug \
                --workspace "$workspace_dir"  \
                --reference-workspace "$___X_CMD_CLAW_AGENT_REFERENCE_WS" \
                "$prompt"
