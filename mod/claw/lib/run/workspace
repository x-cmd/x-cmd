# shellcheck shell=dash

___x_cmd_claw_run_workspace_ensure(){
    local workspace_dir="$1"
    local source_dir="$2"
    local harness="$3"

    if [ ! -d "$workspace_dir" ]; then
        ___x_cmd mkdirp "$workspace_dir"
    fi

    # Ensure missing template files are present without overwriting existing ones
    local targetfp="" i=""
    for i in "$source_dir"/*; do
        [ -e "$i" ] || continue
        fpname="${i#"$source_dir"/}"
        case "$harness" in
            claude*)    [ "$fpname" != "AGENTS.md" ] || continue ;;
            *)          [ "$fpname" != "CLAUDE.md" ] || continue ;;
        esac
        targetfp="$workspace_dir/$fpname"
        [ -e "$targetfp" ] || ___x_cmd cp -r "$i" "$targetfp"
    done
}


___x_cmd_claw_run_workspace_check_prompt_(){
    local workspace_dir="$1"
    local source_dir="$2"
    local harness="$3"

    local agents_file="AGENTS.md"
    case "$harness" in
        claude*)    agents_file="CLAUDE.md" ;;
    esac

    x_=""
    if [ "$workspace_dir/$agents_file" -ot "$___X_CMD_ROOT_METADATA/version_sum" ]; then
        claw:info "Workspace template may have been updated, checking if structure optimization is needed"
        ___x_cmd_cmds touch "$workspace_dir/$agents_file"
        x_="<workspace_check>
The workspace template has been updated. Use it as a reference to evaluate whether your current workspace structure needs improvements.

Reference template: $source_dir/
Current workspace:  $workspace_dir

Guidelines:
- This is a reference only — you decide what to adopt
- Compare structures and selectively apply beneficial changes
- Preserve existing user content and customizations
- Focus on structural gaps or organizational improvements
</workspace_check>"
    fi
}