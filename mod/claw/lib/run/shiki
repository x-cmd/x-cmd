    :
}

___x_cmd_claw_shiki_run(){

    local mq_fp="$1"
    local msg_list=""

    local last_handler_timestamp=""

    while ___x_cmd tailer msg waitunread "$mq_fp"; do
        msg_list="$( ___x_cmd tailer msg recent )"
        ___x_cmd tailer msg commit
        ___x_cmd agent request ""
        ___x_cmd epoch get_
        last_handler_timestamp="$x_"
    done

}
