___x_cmd_claw_run___agentwork___handlemsg___weixin(){
    local imfile="$___X_CMD_CLAW_BOT_HEARTBEAT/current_im_chatid"
    ___x_cmd ensurefp "$imfile"
    printf "%s %s\n" "weixin" "clawbot" > "$imfile"

    ___x_cmd_claw_weixin_has_unread || return 0
    claw:info "Weixin unread messages detected, launching agent request"
    ___x_cmd_claw_run___agentrequest___handlemsg "weixin" "clawbot" "$( ___x_cmd_claw_weixin_get_unread )"
}

