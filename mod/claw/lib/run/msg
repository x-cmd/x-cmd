


___x_cmd_claw_run___agentwork___handlemsg(){
    local msg="$1"

    local chatid
    case "$msg" in
        weixin:*)
                if ___x_cmd worker isalive --ns x-claw-worker --name weixin-clawbot; then
                    :
                else
                    ___x_cmd worker run --ns x-claw-worker --name weixin-clawbot --  ___x_cmd_claw_run___agentwork___handlemsg___weixin
                fi
                ;;
        telegram:*)
                chatid="${msg#*:}"
                if ___x_cmd worker isalive --ns x-claw-worker --name "telegram-${chatid}"; then
                    :
                else
                    ___x_cmd worker run --ns x-claw-worker --name "telegram-${chatid}" -- ___x_cmd_claw_run___agentwork___handlemsg___telegram "${chatid}"
                fi
                ;;
        feishu:*)
                chatid="${msg#*:}"
                if ___x_cmd worker isalive --ns x-claw-worker --name "feishu-${chatid}"; then
                    :
                else
                    ___x_cmd worker run --ns x-claw-worker --name "feishu-${chatid}" -- ___x_cmd_claw_run___agentwork___handlemsg___feishu "${chatid}"
                fi
                ;;
    esac
}


