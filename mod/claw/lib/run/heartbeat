# shellcheck shell=dash

# claw should have a name and timezone.

# x cron add --ns "x-claw/default" ""

___x_cmd_claw_run___agentwork___heartbeat(){
    local current_ts="$1"
    local heartbeat_tsfile="$___X_CMD_CLAW_BOT_HEARTBEAT/lastheartbeat_ts"
    local lastheartbeat_ts=0;
    [ ! -f "$heartbeat_tsfile" ] || read -r lastheartbeat_ts < "$heartbeat_tsfile"
    [ "$(( current_ts - lastheartbeat_ts ))" -ge 0 ] || return 0
    ___x_cmd ensurefp "$heartbeat_tsfile"
    printf "%s\n" "$current_ts" > "$heartbeat_tsfile"

    ___x_cmd cron runonce --ns "x-claw-default"

    # check agent has unread message, and it is not working, if exists, run the agent.
    local imfile="$___X_CMD_CLAW_BOT_HEARTBEAT/current_im_chatid"
    local current_im=""; local current_chatid="";
    [ -f "$imfile" ] || return 0
    read -r current_im current_chatid < "$imfile"

    # Ensure IM service is always online before any operation
    case "$current_im" in
        feishu) ___x_cmd feishu abot service ensure || return $? ;;
        *)      ___x_cmd "$current_im" bot service ensure || return $? ;;
    esac

    local idle_count=0
    local idle_file="$___X_CMD_CLAW_BOT_HEARTBEAT/idle_count"
    local heartbeat_done_file="$___X_CMD_CLAW_BOT_HEARTBEAT/heartbeat_done"
    [ ! -f "$idle_file" ] || read -r idle_count < "$idle_file"

    # Activity: unread message pending to be processed
    if ___x_cmd claw "$current_im" has-unread "$current_chatid" && ! ___x_cmd worker isalive --ns x-claw-default-worker --name "${current_im}-${current_chatid}"; then
        printf "%s\n" "0" > "$idle_file"
        ___x_cmd rmrf "$heartbeat_done_file"
        claw:debug "Unread message detected, launching agent request"
        ___x_cmd_claw_run___agentwork___handlemsg "${current_im}:${current_chatid}"
        return 0
    fi

    # Activity: message worker still running
    if ___x_cmd worker isalive --ns x-claw-default-worker --name "${current_im}-${current_chatid}"; then
        claw:debug "Message worker still running, skipping heartbeat"
        printf "%s\n" "0" > "$idle_file"
        ___x_cmd rmrf "$heartbeat_done_file"
        return 0
    fi

    # No external activity detected: increment idle counter
    # Note: heartbeat worker is internal task, counter keeps growing while it runs
    idle_count=$(( idle_count + 1 ))
    printf "%s\n" "$idle_count" > "$idle_file"
    claw:debug "Tick ${idle_count} — no external pulse detected"

    # Skip if previous heartbeat worker is still running
    if ___x_cmd worker isalive --ns x-claw-default-worker --name x-claw-heartbeat; then
        claw:debug "Previous heartbeat worker is still running, skipping heartbeat"
        return 0
    fi

    # Skip heartbeat agent if already confirmed idle by agent itself
    [ ! -f "$heartbeat_done_file" ] || return 0

    # Skip heartbeat agent during initial observation period (first 3 idle cycles)
    [ "$idle_count" -ge 3 ] || return 0
    [ "$idle_count" -lt 30 ] || return 0
    claw:debug "Launching heartbeat agent for $current_im $current_chatid (idle=$idle_count)"
    ___x_cmd worker run --ns x-claw-default-worker --name x-claw-heartbeat -- ___x_cmd_claw_run___agentrequest___handleheartbeat "$current_im" "$current_chatid"
}

___x_cmd_claw_run_hearbeatgenerator(){
    local mqdir="$1"
    local x_

    ___x_cmd date timestamp_
    ___x_cmd_cmds sleep $(( 60 - (x_ % 60) )) || return 130

    while true; do
        # TODO: Check if the father process is alive. If not. exit.
        x_=; ___x_cmd date timestamp_
        ___x_cmd tailer send "$mqdir" "HEARTBEAT:$x_"
        ___x_cmd_cmds sleep $(( 60 - (x_ % 60) )) || return 130
    done
}
