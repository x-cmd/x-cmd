___x_cmd_claw_service(){
    [ $# -gt 0 ]    ||      set -- --help

    local op="$1";          shift
    case "$op" in
        -h|--help)          ___x_cmd help -m claw service "$@" ; return 0 ;;
        start|stop|restart|status|log|run)
                            ___x_cmd_claw_service_"$op" "$@"      ;;
        *)                  N=claw M="Unknown op -> $op" log:ret:64   ;;
    esac
}

___x_cmd_claw_service_start(){
    [ "$#" -gt 0 ] ||   set -- --help

    local im=;
    local op="$1";          shift
    case "$op" in
        -h|--help)
                    ___x_cmd help -m claw service start "$@" ; return 0 ;;
        feishu|weixin|telegram)
                    im="$op" ;;
        *)          claw:error "Unsupported IM platform: $op"
                    return 1
                    ;;
    esac

    claw:info "Ensuring $im listener is ready"
    ___x_cmd_claw_run___ensure "$im" || {
        claw:error "Failed to start $im listener, claw service startup interrupted"
        return 1
    }

    claw:info "Starting claw service"
    ___x_cmd service start      x-claw-service  --  x-cmd claw service run "$@"

    ___x_cmd sleep 2
    ___x_cmd service isalive x-claw-service || {
        claw:error "Failed to start claw service"
        ___x_cmd service log tail x-claw-service
        return 1
    }

    printf "%s " "status: "; ___x_cmd_claw_service_status
}

___x_cmd_claw_service_stop(){
    [ "$#" -gt 0 ] ||   set -- --help

    local im="$1"; shift
    case "$im" in
        -h|--help)
            ___x_cmd help -m claw service stop "$@" ; return 0 ;;
        feishu|weixin|telegram)
            ;;
        *)      claw:error "Unsupported IM platform: $im"
            return 1
            ;;
    esac

    if ___x_cmd service isalive x-claw-service; then
        if ___x_cmd service isalive "x-$im-listener"; then
            claw:info "Stopping $im listener"
            ___x_cmd service stop       "x-$im-listener"
        fi

        claw:info "Stopping claw service"
        ___x_cmd service stop       x-claw-service
        ___x_cmd_cmds pkill -f "claw service run"
    else
        claw:warn "claw service is not running"
    fi
}

___x_cmd_claw_service_restart(){
    [ "$#" -gt 0 ] ||   set -- --help

    local im="$1"; shift
    case "$im" in
        -h|--help)
                    ___x_cmd help -m claw service restart "$@" ; return 0 ;;
        feishu|weixin|telegram)
                    ;;
        *)          claw:error "Unsupported IM platform: $im"
                    return 1
                    ;;
    esac

    if ___x_cmd service isalive x-claw-service; then
        ___x_cmd_claw_service_stop "$im" || {
            claw:warn "Claw service is not stopped. Please try 'x service stop --force x-claw-service'"
            return 1
        }
    fi

    ___x_cmd_claw_service_start "$im"
}

___x_cmd_claw_service_status(){
    ___x_cmd service status     x-claw-service
}

___x_cmd_claw_service_log(){
    ___x_cmd service log tail     x-claw-service
}

# Fetch msg from the msgloop

___x_cmd_claw_service_run(){
    local im="${1:-"weixin"}"
    case "$im" in
        weixin|telegram|feishu)
            ___x_cmd claw run "$im" || return $?
            ;;
        *)  claw:error "Unsupported IM platform: $im"
            return 1
            ;;
    esac
}

