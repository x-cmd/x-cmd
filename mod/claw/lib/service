}

___x_cmd_claw_service_restart(){
    ___x_cmd service restart    x-claw-service-0
}

___x_cmd_claw_service_isalive(){
    ___x_cmd service isalive    x-claw-service-0
}


# Fetch msg from the msgloop

___x_cmd_claw_service_run(){
    local name

    while [ $# -gt 0 ]; do
        case "$1" in
            --name)     name="$1" ; shift ;;
        esac
    done

    case "$name" in
        "")             name=claw-service-0 ;;
        claw-service-*) ;;
        *)              name="claw-service-$name" ;;
    esac

    while true; do
        :
    done
}

