# shellcheck shell=dash

___x_cmd_slash_cat(){
    case "$1" in
        -h|--help) ___x_cmd help -m slash cat; return ;;
    esac
    ___x_cmd_slash_check || return $?
    [ -f "$___X_CMD_SLASH_CONFIG" ] || N=slash M="Not found config file" log:ret:1
    ___x_cmd_cmds cat "$___X_CMD_SLASH_CONFIG"
}
