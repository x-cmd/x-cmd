# shellcheck shell=dash

xrc:mod:lib     umami       event/ls  event/field  event/stat

# https://umami.is/docs/api/events
# https://umami.is/docs/api/event-data
___x_cmd_umami_event(){
    local op="$1"; shift
    case "$op" in
        ls|field|stat)  ___x_cmd_umami_event_"$op"    "$@" ;;
        -h|--help)      ___x_cmd help -m umami event  "$@" ;;
        *)              M="Not found command - 'x umami event $op'" N=umami log:ret:1
    esac
}
