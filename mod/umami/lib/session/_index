# shellcheck shell=dash

xrc:mod:lib     umami       session/stat

# https://v2.umami.is/docs/api/sessions-api
___x_cmd_umami_session(){
    local op="$1"; shift
    case "$op" in
        stat)       ___x_cmd_umami_session_stat   "$@" ;;
        ls|active)  ___x_cmd_umami_session_ls    "$@" ;;
        -h|--help)  ___x_cmd help -m umami session "$@" ;;
        *)          M="Not found command - 'x umami session $op'" N=umami log:ret:1
    esac
}
