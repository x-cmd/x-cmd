# shellcheck shell=dash

xrc:mod:lib     umami       me/ls

# https://v2.umami.is/docs/api/me-api
___x_cmd_umami_me(){
    local op="$1"; shift
    case "$op" in
        -h|--help)      ___x_cmd help -m umami me  "$@" ;;
        ls)              ___x_cmd_umami_me_ls       "$@" ;;
        *)              M="Not found command - 'x umami me $op'" N=umami log:ret:1
    esac
}
