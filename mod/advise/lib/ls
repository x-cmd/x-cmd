
___x_cmd_advise_ls(){
    local X_help_cmd; X_help_cmd='___x_cmd help -m advise ls' help:arg:parse
    [ ! -d "$___X_CMD_ADVISE_TMPDIR" ] || {
        local l=""
        ___x_cmd find "$___X_CMD_ADVISE_TMPDIR" -path "$___X_CMD_ADVISE_TMPDIR/name_*" -type f | while read -r l; do
            printf "%s\n" "${l#"$___X_CMD_ADVISE_TMPDIR/name_"}"
        done
    }
}
