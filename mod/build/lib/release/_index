# shellcheck shell=dash

xrc:mod:lib build release/apk release/apt release/archlinux release/asdf release/brew release/cargo release/conda release/deb release/deno release/maven release/npm release/pacman release/pip release/rpm

___x_cmd_build_release(){
    [ $# -gt 0 ] || {
        ___x_cmd help -m build release
        return
    }

    local op="$1"
    shift

    case "$op" in
        apk|apt|archlinux|asdf|brew|cargo|conda|deb|deno|maven|npm|pacman|pip|rpm)
            ___x_cmd_build_release_"${op}" "$@" ;;
        *)  ___x_cmd help -m build release ;;
    esac
}
