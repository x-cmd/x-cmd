# GF(256) Arithmetic Tables
# Polynomial: x^8 + x^4 + x^3 + x^2 + 1 (0x11D)
# Precomputed for performance

BEGIN {
    # Anti-log (exp) table: exp[i] = 2^i in GF(256)
    # exp[0] = 1, exp[1] = 2, exp[2] = 4, ... exp[255] wraps
    split("1 2 4 8 16 32 64 128 29 58 116 232 205 135 19 38 76 152 45 90 180 117 234 201 143 3 6 12 24 48 96 192 157 39 78 156 37 74 148 53 106 212 181 119 238 193 159 35 70 140 5 10 20 40 80 160 93 186 105 210 185 111 222 161 95 190 97 194 153 47 94 188 101 202 137 15 30 60 120 240 253 231 211 187 107 214 177 127 254 225 223 163 91 182 113 226 217 167 75 150 49 98 196 145 7 14 28 56 112 224 221 163 89 178 121 242 249 239 195 155 43 86 172 121 242 237 207 131 11 22 44 88 176 125 250 245 235 203 139 23 46 92 184 109 218 173 71 142 0 0", exp_tbl)

    # Log table: log[x] = i where exp[i] = x (x != 0)
    # log[1] = 0, log[2] = 1, log[4] = 2, ...
    split("0 0 1 25 2 50 26 198 3 223 51 238 27 104 199 75 4 100 224 14 52 141 239 129 28 193 105 248 200 8 76 113 5 153 101 47 15 225 36 53 142 232 6 130 21 54 208 183 29 12 106 249 39 201 9 68 77 114 224 152 220 7 134 3 23 109 16 255 224 122 217 102 151 196 28 232 182 221 225 38 169 15 78 141 111 225 48 91 202 214 250 87 159 45 110 237 117 227 129 199 71 24 126 115 35 210 137 181 85 215 233 209 134 222 103 149 118 219 180 197 197 123 92 211 230 231 6 166 124 30 107 249 108 80 161 53 241 10 82 158 33 56 162 109 120 175 62 175 198 229 185 84 98 228 20 165 88 202 66 63 145 131 186 234 146 172 58 169 227 150 116 59 14 105 210 55 155 148 137 216 115 41 27 154 83 111 229 164 135 143 109 106 143 195 190 248 154 27 98 79 230 212 149 96 228 108 189 191 212 156 253 188 121 205 138 195 122 207 148 146 57 25 218 14 170 30 183 191 140 177 229 51 245 235 186 48 235 220 21 167 140 160 204 209 17 22 205 246 234 238 206 251 252 254 239 203 140 60 118 192 47 43 112 46 236 70 86 211 32 87 74 18 177 158 116 242 144 13 163 99 132 94 204 253 214 250 186 188 213 235 242 188 143 89 99 184 231 97 116 73 88 183 123 119 188 245 94 182 49 226 36 80 64 242 168 5 93 170 107 23 228 244 240 81 179 90 100 243 233 246 152 147 67 69 156 31 151 167 215 24 0", log_tbl)

    # Multiplication: a * b in GF(256)
    # returns 0 if either is 0
    # uses exp[log[a] + log[b] mod 255]
}

function gf_mul(a, b,    t) {
    if (a == 0 || b == 0) return 0
    t = (log_tbl[a+1] + log_tbl[b+1]) % 255
    return exp_tbl[t+1]
}

function gf_div(a, b,    t) {
    if (a == 0) return 0
    if (b == 0) return 0  # error
    t = (255 + log_tbl[a+1] - log_tbl[b+1]) % 255
    return exp_tbl[t+1]
}

function gf_pow(a, n,    i, r) {
    r = 1
    for (i = 0; i < n; i++) {
        r = gf_mul(r, a)
    }
    return r
}

function gf_inverse(a) {
    if (a == 0) return 0  # undefined
    return exp_tbl[(255 - log_tbl[a+1]) % 255 + 1]
}
