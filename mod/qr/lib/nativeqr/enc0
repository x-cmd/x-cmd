# shellcheck shell=dash
# Pure awk QR encoder - enc0 command

# Generate precompiled tables and invoke awk
___x_cmd_qr_enc0(){
    local data="${1:-}"

    # Generate precompiled tables if needed, get path
    local prexorpath; prexorpath="$(___x_cmd_qr_prexor)" || return 1

    # Get the encode.awk path - in v/x0/mod structure
    local encode_awk="$___X_CMD_ROOT/v/x0/mod/qr/lib/qr/encode.awk"

    # Create temp file with combined scripts
    local tmpcombine="/tmp/qr_combine_$$.awk"
    ___x_cmd_cmds cat "$prexorpath" "$encode_awk" | grep -v '@include' > "$tmpcombine"

    ___x_cmd gawk -v DATA="$data" -f "$tmpcombine"

    ___x_cmd_cmds rm -f "$tmpcombine"
}
