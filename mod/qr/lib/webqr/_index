# webqr - QR encode/decode via the api.qrserver.com web service
# shellcheck shell=dash
#
# Privacy: This group talks to a third-party API (api.qrserver.com, by goQR.me /
# Foundata GmbH). It is NOT part of x-cmd. They log the request referrer and IP
# (not QR contents) per their ToS. Every invocation prints a reminder to stderr.

xrc:mod:lib     qr      webqr/webenc
xrc:mod:lib     qr      webqr/webdec
