# shellcheck shell=dash

xrc:mod:lib     skill0   __runcmd

___x_cmd_skill0___main(){
    [ "$#" -gt 0 ] ||   set -- --help

    local op="$1";      shift
    case "$op" in
        -h|--help)      ___x_cmd help -m skill0 "$@";    return 0 ;;

        *)              N=skill0 M="Unknown subcmd -> $op" log:ret:64 ;;
    esac
}


# promote skill0 into the folder.

___x_cmd_skill0_ls(){
    :
}

