# shellcheck shell=dash

xrc:mod:lib weixin    bot/send

___x_cmd_weixin_bot(){
    local X_help_cmd='___x_cmd_weixin___help bot'
    help:arg-null:parse

    local op="$1"
    case "$op" in
        send) shift
            ___x_cmd_weixin_bot_send "$@" ;;
        *)  ___x_cmd_weixin_u_subcmd_invalid bot "$@" ;;
    esac
}
