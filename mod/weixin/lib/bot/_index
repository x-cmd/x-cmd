# shellcheck shell=dash

xrc:mod:lib weixin      bot/send bot/recv bot/data bot/service

___x_cmd_weixin_bot(){
    [ $# -gt 0 ]    ||  set -- --help

    local op="$1" ;     shift
    case "$op" in
        -h|--help)      ___x_cmd help -m weixin bot "$@" ; return 0 ;;
        send|recv|data|service)
                        ___x_cmd_weixin_bot_"$op"                    "$@" ;;
        *)              ___x_cmd_weixin_u_subcmd_invalid bot "$op"  "$@" ;;
    esac
}

