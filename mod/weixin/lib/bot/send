___x_cmd_weixin_bot_send_raw(){
    local X_help_cmd='___x_cmd_weixin___help bot send raw'
    help:arg:parse

    local json_output=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -j|--json) json_output=1; shift ;;
            -h|--help) ___x_cmd_weixin___help bot send raw; return 0 ;;
            *) break ;;
        esac
    done

    local raw="${1}"
    [ "$raw" = "-" ] && raw="$(___x_cmd_cmds_cat)"
    [ -z "$raw" ] && { weixin:error "JSON content required"; return 1; }

    local resp; resp="$(___x_cmd_weixin_u_curl POST "/ilink/bot/sendmessage" -d "$raw")"

    if [ -n "$json_output" ]; then
        printf "%s\n" "$resp"
    else
        local ret; ret="$(printf "%s" "$resp" | ___x_cmd jo env .ret)"
        if [ "$ret" = "0" ]; then
            ___x_cmd_ui_tf true "Sent message successfully"
        else
            ___x_cmd_ui_tf false "Failed to send message:" "$resp"
        fi
    fi
}

# Internal helper: send uploaded media
___x_cmd_weixin_bot___send_uploaded(){
    local to_user_id="$1"
    local context_token="$2"
    local msg_type="$3"
    local encrypt_param="$4"
    local file_name="${5:-}"
    local json_output="${6:-}"

    # Map msg_type to API type: image=2, file=4, video=5
    local api_type
    case "$msg_type" in
        image) api_type=2 ;;
        file)  api_type=4 ;;
        video) api_type=5 ;;
        *)     api_type=1 ;;
    esac

    # Build media reference
    local media_json; media_json="$(___x_cmd jo dict encrypt_query_param:"$encrypt_param")"

    # Build content based on type
    local content_json
    case "$msg_type" in
        image) content_json="$(___x_cmd jo dict media:"$media_json")" ;;
        file)  content_json="$(___x_cmd jo dict media:"$media_json" file_name:"$file_name")" ;;
        video) content_json="$(___x_cmd jo dict media:"$media_json")" ;;
    esac

    local msg_json; msg_json="$(___x_cmd jo dict \
        msg_type:="$api_type" \
        content:"$content_json" \
        to_user_id:"$to_user_id" \
        context_token:"$context_token")"

    local full_json; full_json="$(___x_cmd jo dict \
        msg:"$msg_json" \
        base_info:"$(___x_cmd jo dict channel_version:'"x-cmd-weixin-1.0.0"')")"

    local resp; resp="$(___x_cmd_weixin_u_curl POST "/ilink/bot/sendmessage" -d "$full_json")"

    if [ -n "$json_output" ]; then
        printf "%s\n" "$resp"
    else
        local ret; ret="$(printf "%s" "$resp" | ___x_cmd jo env .ret)"
        if [ "$ret" = "0" ]; then
            ___x_cmd_ui_tf true "Sent $msg_type successfully"
        else
            ___x_cmd_ui_tf false "Failed to send $msg_type:" "$resp"
        fi
    fi
}
