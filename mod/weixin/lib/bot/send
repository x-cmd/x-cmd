# shellcheck shell=dash

___x_cmd_weixin_bot_send(){
    local X_help_cmd='___x_cmd_weixin___help bot send'
    help:arg-null:parse

    local op="$1"
    case "$op" in
        text|image|file|video|raw) shift
            "___x_cmd_weixin_bot_send_$op" "$@"
            ;;
        *)  ___x_cmd_weixin_u_subcmd_invalid "bot send" "$op"
            ;;
    esac
}

___x_cmd_weixin_bot_send_text(){
    local X_help_cmd='___x_cmd_weixin___help bot send text'
    help:arg:parse

    local to_user_id=""
    local json_output=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -j|--json) json_output=1; shift ;;
            --to) to_user_id="$2"; shift 2 ;;
            -h|--help) ___x_cmd_weixin___help bot send text; return 0 ;;
            *) break ;;
        esac
    done

    local text="$1"
    [ -n "$text" ] || { weixin:error "Text content required"; return 1; }
    [ -n "$to_user_id" ] || { weixin:error "Recipient user ID required (--to)"; return 1; }

    # Get context token
    local context_token; context_token="$(___x_cmd_weixin_util_get_context_token "$to_user_id")" || {
        weixin:error "Failed to get context token"
        return 1
    }

    # Build and send message
    local msg_json; msg_json="$(___x_cmd jo dict \
        msg_type:=1 \
        content:"$(___x_cmd jo dict text:"$text")" \
        to_user_id:"$to_user_id" \
        context_token:"$context_token")"

    local full_json; full_json="$(___x_cmd jo dict \
        msg:"$msg_json" \
        base_info:"$(___x_cmd jo dict channel_version:'"x-cmd-weixin-1.0.0"')")"

    local resp; resp="$(___x_cmd_weixin_u_curl POST "/ilink/bot/sendmessage" -d "$full_json")"

    if [ -n "$json_output" ]; then
        printf "%s\n" "$resp"
    else
        local ret; ret="$(printf "%s" "$resp" | ___x_cmd jo env .ret)"
        if [ "$ret" = "0" ]; then
            ___x_cmd_ui_tf true "Sent text message successfully"
        else
            ___x_cmd_ui_tf false "Failed to send message:" "$resp"
        fi
    fi
}

___x_cmd_weixin_bot_send_image(){
    local X_help_cmd='___x_cmd_weixin___help bot send image'
    help:arg:parse

    local file_path=""
    local to_user_id=""
    local json_output=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -j|--json) json_output=1; shift ;;
            --file_path) file_path="$2"; shift 2 ;;
            --to) to_user_id="$2"; shift 2 ;;
            -h|--help) ___x_cmd_weixin___help bot send image; return 0 ;;
            *) break ;;
        esac
    done

    [ -n "$file_path" ] || { weixin:error "File path required (--file_path)"; return 1; }
    [ -f "$file_path" ] || { weixin:error "File not found: $file_path"; return 1; }
    [ -n "$to_user_id" ] || { weixin:error "Recipient user ID required (--to)"; return 1; }

    # Upload to CDN first
    local upload_result; upload_result="$(___x_cmd_weixin_util_upload_media "$file_path" "$to_user_id" "image")" || {
        weixin:error "Failed to upload image"
        return 1
    }

    local encrypt_param; encrypt_param="$(printf "%s" "$upload_result" | ___x_cmd jo env .encrypt_query_param)"

    # Get context token
    local context_token; context_token="$(___x_cmd_weixin_util_get_context_token "$to_user_id")" || return 1

    # Send uploaded image
    ___x_cmd_weixin_bot___send_uploaded "$to_user_id" "$context_token" "image" "$encrypt_param" "" "$json_output"
}

