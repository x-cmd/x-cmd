# shellcheck shell=dash

xrc:mod:lib weixin listen/poll

___x_cmd_weixin_listen(){
    local X_help_cmd='___x_cmd_weixin___help listen'
    help:arg-null:parse

    local op="$1"
    case "$op" in
        poll) shift
            ___x_cmd_weixin_listen_poll "$@"
            ;;
        *)  ___x_cmd_weixin_u_subcmd_invalid listen "$@"
            ;;
    esac
}
