
___X_CMD_FIND_IGNORE='.DS_Store
.git
.svn
.hg
node_modules
__pycache__
.venv
.gradle
.mvn
.build
.cache
.tmp
'

___x_cmd_find_ignore_add_(){
    while [ $# -gt 0 ]; do
        ___X_CMD_FIND_IGNORE="${___X_CMD_FIND_IGNORE}${1}${___X_CMD_UNSEENCHAR_NEWLINE}"
        shift
    done
}

___x_cmd_find_ignore_home___addhome_(){
    while [ $# -gt 0 ]; do
        { [ -n "$prune_hidden" ] && ___x_cmd_find_ignore_ishiddenname "$1" ; } ||   \
            ___X_CMD_FIND_HOMEIGNORE="${___X_CMD_FIND_HOMEIGNORE}${1}${___X_CMD_UNSEENCHAR_NEWLINE}"
        shift
    done
}

___x_cmd_find_ignore_home(){
    local rootfp="$1"
    local prune_hidden="$2"

    local x_
    ___x_cmd abspath_ "$rootfp" ||  N=find M="Unknown rootfp -> $rootfp" log:ret:64
    [ "${x_%/}" = "$HOME" ]     ||  return 0

    ___x_cmd os name_
    case "$x_" in
        darwin) ___x_cmd_find_ignore_home___addhome_        \
                    Applications Library .Trash .localized  \
                    Desktop Documents Pictures Movies Music Public              ;;
        linux)  ___x_cmd_find_ignore_home___addhome_ .dbus .pki                 ;;
        win)    ___x_cmd_find_ignore_home___addhome_ AppData "Application Data" ;;
    esac

    ___x_cmd_find_ignore_home___addhome_ \
        .x-cmd.root .codex .agent .crush .cursor .docker .claude .cargo .bun .cherrystudio \
        .npm .yarn .pnpm-store .nvm .node-gyp .volta .deno \
        .rustup .pyenv .conda .sdkman .rbenv .jenv .n \
        .config .local .vscode .vscode-server .vscode-shared \
        .gradle .m2 .sbt .ivy2 \
        .terraform.d .minikube .kube .helm \
        .ipython .jupyter .pandoc \
        .vim .oh-my-zsh .tmux .emacs.d \
        .android .flutter .electron-gyp \
        .gnupg .pixi .nix-profile .nix-defexpr .nix-channels .xargo .swiftpm \
        .copilot .gemini .trae .cline .cagent .kimi \
        .warp .agent-browser .thumbnails .sandboxd
}

___x_cmd_find_ignore_ishiddenname(){
    case "$1" in
        .*)     return 0 ;;
        *)      return 1 ;;
    esac
}

___x_cmd_find_ignore_strip_hidden_(){
    local varname="$1"
    local _val
    eval "_val=\"\${$varname}\""
    local filtered=""
    while read -r name; do
        [ -n "$name" ] || continue
        ___x_cmd_find_ignore_ishiddenname "$name" || filtered="${filtered}${name}${___X_CMD_UNSEENCHAR_NEWLINE}"
    done <<A
$_val
A
    eval "$varname=\"\$filtered\""
}

___X_CMD_FIND_WHITELIST=""

___x_cmd_find_whitelist_add_(){
    while [ $# -gt 0 ]; do
        ___X_CMD_FIND_WHITELIST="${___X_CMD_FIND_WHITELIST}${1}${___X_CMD_UNSEENCHAR_NEWLINE}"
        shift
    done
}

___x_cmd_find_in_whitelist_(){
    case "${___X_CMD_UNSEENCHAR_NEWLINE}${___X_CMD_FIND_WHITELIST}" in
        *"
${1}
"*) return 0 ;;
        *) return 1 ;;
    esac
}

___x_cmd_find_whitelist_filter_(){
    [ -n "$___X_CMD_FIND_WHITELIST" ] || return 0

    local varname _val filtered
    for varname in ___X_CMD_FIND_IGNORE ___X_CMD_FIND_HOMEIGNORE; do
        eval "_val=\"\${$varname}\""
        filtered=""
        while IFS= read -r name; do
            [ -n "$name" ] || continue
            ___x_cmd_find_in_whitelist_ "$name" || filtered="${filtered}${name}${___X_CMD_UNSEENCHAR_NEWLINE}"
        done <<A
$_val
A
        eval "$varname=\"\$filtered\""
    done
}
