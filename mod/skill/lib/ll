___x_cmd_skill_ll___fzapp_(){
    x_=""
    ___x_cmd_runmode_allow_manual || N=skill M="Not supported in non-interactive mode" log:ret:64

    ___x_cmd_skill___data_check || return $?
    x_="$( ___X_CMD_RUNMODE="$___X_CMD_RUNMODE" ___x_cmdexe skill ll --fzdata )" || return $?

    [ -n "$x_" ] || return 1
}

___x_cmd_skill_ll___fz_data(){
    ___x_cmd_skill_ll___raw \
        | ___x_cmd_cmds awk -F'\t' -f "$___X_CMD_ROOT_MOD/skill/lib/awk/fz_data.awk" \
        | ___x_cmd_skill___fzf  \
            --prompt "[Skills] > " \
            --header="$(___x_cmd_cmds awk -f "$___X_CMD_ROOT_MOD/skill/lib/awk/fz_header.awk")" \
            --preview='___x_cmdexe skill info {-1}'  \
            --preview-window='bottom:15,wrap'                  \
        | ___x_cmd_cmds awk '{print $NF}'
}

___x_cmd_skill_ll___fz_preview(){
    local id="${1}"
    ___x_cmd skill info "$id"
}

___x_cmd_skill_ll___fzapp(){
    local x_=""; ___x_cmd_skill_ll___fzapp_ "$@" || return $?
    ___x_cmd skill info "$x_"
}

___x_cmd_skill_ll___github(){
    ___x_cmd_skill_ll___github_raw "$@" | awk -F'\t' '
    {
        name = $1
        url = $2
        desc = $3
        if (length(name) > max_name) max_name = length(name)
        if (length(url) > max_url) max_url = length(url)
        lines[NR] = $0
    }
    END {
        if (max_name < 12) max_name = 12
        if (max_url < 30) max_url = 30
        fmt = "\033[0;33m%-*s\033[0m \033[0;35m%-*s\033[0m \033[0;36m%s\033[0m\n"

        for (i = 2; i <= NR; i++) {
            split(lines[i], f, "\t")
            printf fmt, max_name, f[1], max_url, f[2], f[3]
        }
    }'
}

___x_cmd_skill_ll___github_raw(){
    local url="$1"

    local owner; local repo
    owner="${url#https://github.com/}"
    owner="${owner%.git}"
    repo="${owner#*/}"
    owner="${owner%/*}"
    [ -n "$owner" ] && [ -n "$repo" ] || {
        N=skill M="Invalid GitHub URL: $url" log:ret:64
    }

    local cache_dir="$___X_CMD_SKILL_DATA_DIR/github/${owner}/${repo}"
    if [ ! -d "$cache_dir" ]; then
        ___x_cmd_skill___data_fromgithub "$owner" "$repo" "$cache_dir" || return $?
    fi

    local all_skills_data; all_skills_data="$(___x_cmd_cmds find "$cache_dir" -mindepth 1 -type f -name 'SKILL.md' 2>/dev/null)"
    [ -n "$all_skills_data" ] || {
        N=skill M="No skills found in ${owner}/${repo}" log:ret:1
    }

    local skill_data
    printf "%s\t%s\t%s\n" "name" "url" "description"
    while read -r skill_data; do
        local skill_dir="${skill_data%/SKILL.md}"
        local name="${skill_dir##*/}"

        local desc=""; local x_=""
        ___x_cmd_skill_ls___preview_get_file_desc_ "$skill_data"
        desc="${x_:-"(No description)"}"

        local IFS="$___X_CMD_UNSEENCHAR_HT"
        printf "%s\t%s\t%s\n" "$name" "$url" "$desc"
    done <<A
$all_skills_data
A
}


