# shellcheck shell=dash

# Original from x-bash/ls

___x_cmd_mac_mem(){
    local fmt=auto   
    # TODO: tsv, csv, monitor .

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)      ___x_cmd help -m mac mem; return ;;
            *)              break ;;
        esac
    done

    ___x_cmd_cmds vm_stat | ___x_cmd_cmds_awk -f "$___X_CMD_ROOT_MOD/ls/lib/cpu/vm_stat.awk"
}


