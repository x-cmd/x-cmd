# shellcheck shell=dash

xrc:mod:lib     ossinsight       stargazer/ls

# https://ossinsight.io/docs/api/stargazers
___x_cmd_ossinsight_stargazer(){
    local op="$1"; shift
    case "$op" in
        -h|--help)      ___x_cmd help -m ossinsight stargazer "$@" ;;
        ls|countries|history|orgs)    ___x_cmd_ossinsight_stargazer_"$op" "$@" ;;
        *)              M="Not found command - 'x ossinsight stargazer $op'" N=ossinsight log:ret:1 ;;
    esac
}