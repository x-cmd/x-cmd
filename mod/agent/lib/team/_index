
alias ret:if:130='case $? in 130) return 130 ; esac'

___x_cmd_agent_team(){
    :
}

# A team should handle the work in the user scope, even in github/hub scope.

___x_cmd_agent_team_init(){
    :
}

___x_cmd_agent_team_run(){
    local mq_file="${1}"
    local mq_last_handle="${2}"
    {
        ___x_cmd tail -f "$mq_file"
    } | {
        ___x_cmd_agent_team_dispatch
    }
}

___x_cmd_agent_team_dispatch(){
    local msg
    local timestamp

    while read -r msg; do
        case "$msg" in
            HEARTBEAT)
                read -r timestamp
                ___x_cmd_agent_team_onheartbeat "$timestamp"
                case $? in
                    130)    N=agent M="Exit because interrupted." log:ret:130 ;;
                esac
                ;;

            IMMSG)
                read -r timestamp && read -r msg
                case $? in
                    130)    N=agent M="Exit because interrupted." log:ret:130 ;;
                esac
                ___x_cmd_agent_team_onim "$timestamp" "$msg"
                ;;

            ROOT)
                read -r timestamp && read -r msg
                case $? in
                    130)    N=agent M="Exit because interrupted." log:ret:130 ;;
                esac
                ___x_cmd_agent_team_onlocalctrl "$timestamp" "$msg"
                ;;

            "") ;;
            *)  agent:error "Unknown msg -> $msg" ;;
        esac
        # record ID
    done
}

___x_cmd_agent_team_dispatch_onheartbeat(){
    local timestamp="$1"

    ___x_cmd agent team workon -f "$HEARDBEAD_MD"
}

# maximum permission
___x_cmd_agent_team_dispatch_onlocalctrl(){
    local timestamp="$1"
    ___x_cmd agent team workon -f "$HEARDBEAD_MD"
}

# limited permission
# Let's AI decide send how many messages back. And how to send.
___x_cmd_agent_team_dispatch_onim(){
    local timestamp="$1"
    local msg="$2"

    local IFS="$___X_CMD_UNSEENCHSR_HT"

    local vendor
    local chatid
    local msg

    {
        { read -r vendor && read -r chatid; } || return 130
    }<<A
$msg
A

    ___x_cmd_agent_team_sendmsg         \
        --session "$vendor-$chatid"     \
        --recvts "$timestamp" --tsvmsg "$msg"

}

