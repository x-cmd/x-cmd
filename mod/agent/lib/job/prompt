# shellcheck shell=dash disable=2154,2034

# Variable mappings for prompt templates
# Each key is a placeholder used in prompt/*.txt files
# Each value is the shell variable name to substitute
___x_cmd_agent_job___prompt_mappings(){
    local jobdir="${1}"
    local planfile="${2}"
    local agentfile="${3}"
    local response_file="${4}"
    local donefile="${5}"
    local iter="${6}"
    local vlid="${7}"
    local loop_context="${8}"

    local user_pwd=""
    if [ -r "$jobdir/PLAN.md" ]; then
        user_pwd="$(___x_cmd_cmds grep "^Pwd: " "$jobdir/PLAN.md" 2>/dev/null | ___x_cmd_cmds head -n 1)"
        user_pwd="${user_pwd#Pwd: }"
    fi
    [ -z "$user_pwd" ] && user_pwd="$jobdir"

    printf "PLAN-FILE %s\n" "$planfile"
    printf "DESCRIPTION-FILE %s\n" "$planfile"
    printf "AGENTS-FILE %s\n" "$agentfile"
    printf "JOB-DIR %s\n" "$jobdir"
    printf "USER-PWD %s\n" "$user_pwd"
    printf "RESPONSE-FILE %s\n" "$response_file"
    printf "DONE-FILE %s\n" "$donefile"
    printf "ITER %s\n" "$iter"
    printf "VLID %s\n" "$vlid"
    printf "LOOP-CONTEXT %s\n" "$loop_context"
}

# Read a prompt template, append raw template, then append variable mappings
___x_cmd_agent_job___get_prompt(){
    local op="${1}"

    local prompt_file="$___X_CMD_ROOT_MOD/agent/lib/job/prompts/${op}.txt"
    [ -f "$prompt_file" ] || return 1

    case "$op" in
        adjust|iter) ;;
        *) return 1 ;;
    esac

    # Output raw template
    ___x_cmd_cmds cat "$prompt_file"

    # Output variable mappings
    printf "\n"
    ___x_cmd_agent_job___prompt_mappings \
        "$jobdir" "$planfile" "$agentfile" \
        "$response_file" "$donefile" "$iter" "$vlid" "$loop_context"
}
