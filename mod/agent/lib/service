# msg design ...

___x_cmd_agent_service___running_harness_(){
    case "$harness" in
        kimi-cli)       x_="$( ___x_cmd kimi     -C -c "$x_" )" ;;
        claude)         x_="$( ___x_cmd claude   -c -p "$x_" )" ;;
        *)              N=agent M="Unsupported harness -> $harness" log:ret:1 ;;
    esac
}
