___x_cmd_agent_service___running(){
    local x_
    ___x_cmd pidofsubshell_

    local msgfolder="$___X_CMD_ROOT_DATA/agent/service/msg/$x_"
    local msgfolder_todo="$msgfolder/todo"

    ___x_cmd mkdirp "$msgfolder"

    local fp=""

    local harness

    while [ $# -gt 0 ]; do

        # keep continue

        ___x_cmd fsiter --lsfile_ "$msgfolder_todo"

        while read -r fp; do
            [ -f "$fp" ]  || continue

            ___x_cmd rat_ "$fp"
            ___x_cmd_agent_service___running_harness_

        done <<A
$x_
A

        # In the future, we will use the a recv message mode.
        ___x_cmd sleep 2 || return $?
    done

}

