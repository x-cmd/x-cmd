# shellcheck shell=dash

xrc:mod:lib     agent   webfetch

___x_cmd_agent___main(){
    [ "$#" -gt 0 ] ||   set -- --help

    local op="$1";      shift
    case "$op" in
        -h|--help)      ___x_cmd help -m agent "$@";    return 0 ;;

        webfetch)
                        ;;


        *)              N=agent M="Unknown subcmd -> $op" log:ret:64 ;;
    esac
}

___x_cmd_agent_squad(){
    :
}

___x_cmd_agent_default(){
    :
}

___x_cmd_agent_kimi(){
    :
}

___x_cmd_agent_claude(){
    :
}

___x_cmd_agent_codex(){
    :
}
