# shellcheck shell=dash

xrc:mod:lib     agent       setup webfetch util unify cfg one service browser request/_index job/_index chat/_index run/_index

___x_cmd_agent___main(){
    [ "$#" -gt 0 ] ||       set -- --help

    local op="$1";          shift
    case "$op" in
        -h|--help)          ___x_cmd help -m agent      "$@" ;      return 0 ;;

        webfetch)           ___x_cmd_agent_webfetch     "$@" ;;
        browser)            ___x_cmd_agent_browser      "$@" ;;

        --setup|setup)      ___x_cmd_agent_setup        "$@" ;;
        --cfg|--cur|init)   ___x_cmd_agent_"${op#--}"   "$@" ;;

        skill)              ___x_cmd skill              "$@" ;;
        scmd|slashcommand)  ___x_cmd scmd               "$@" ;;

        unify)              ___x_cmd_agent_unify        "$@" ;;
        isready)            ___x_cmd_agent_isready      "$@" ;;

        zero)               ___x_cmd_agent_zero         "$@" ;;
        one)                ___x_cmd_agent_one          "$@" ;;
        yolo)               ___x_cmd_agent_one --yolo   "$@" ;;

        run|request)        ___x_cmd_agent_"$op"        "$@" ;;
        chat)               ___x_cmd_agent_chat         "$@" ;;
        job)                ___x_cmd_agent_job          "$@" ;;

        *)                  N=agent M="Unknown subcmd -> $op" log:ret:64 ;;
    esac
}
