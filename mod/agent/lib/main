# shellcheck shell=dash

xrc:mod:lib     agent       setup util unify cfg init browser request/_index job/_index chat/_index session/_index

___x_cmd_agent___main(){
    [ "$#" -gt 0 ] ||       set -- --help

    local op="$1";          shift
    case "$op" in
        -h|--help)          ___x_cmd help -m agent      "$@" ;      return 0 ;;

        webfetch)           ___x_cmd_agent_webfetch     "$@" ;;
        browse|browser)     ___x_cmd ab                 "$@" ;;


        --setup|setup)      ___x_cmd_agent_setup        "$@" ;;
        --is-setup)         ___x_cmd_agent_is_setup     "$@" ;;
        --cfg|--cur|init)   ___x_cmd_agent_"${op#--}"   "$@" ;;

        skill)              ___x_cmd skill              "$@" ;;

        run|ps)             ___x_cmd_agent_job_"$op"    "$@" ;;

        request|chat|job|session|\
        unify|isready)
                            ___x_cmd_agent_"$op"        "$@" ;;

        *)                  N=agent M="Unknown subcmd -> $op" log:ret:64 ;;
    esac
}
