
# run with multiple agent.

# x agent run --yolo <folder>/agent.md
# x agent run --yolo <folder>
# Basic permission

# allow read, webfetch, websearch = 1

# subagent 应该是一种可以观测和控制的底层行为

___x_cmd_agent_run(){
    local yolo=""
    local skill_list=""
    local jobfp=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --yolo)     yolo=1 ;    shift ;;    # -9
            --skill)    skill_list="${skill_list} $2" ; arg:2:shift ;;

            --jobfp)    jobfp="$2" ; arg:2:shift ;;

            --goal)     goal="$2" ; arg:2:shift ;;

            --prompt)   prompt="$3" ; arg:2:shift ;;

            # gaining experience
            # pass to the job list.
            --exp)      experience="$2" ; arg:2:shift ;;

                        # Search the home folder, or search the x-cmd registry, or just
            # --agent)    agent_list="${agent_list} $2" ; arg:2:shift ;;

            *)          break ;;
        esac
    done

    [ $# -gt 0 ]    ||  N=agent M="Please provide agent folder to exec." log:ret:64

    local targetfp="$1" ; shfit

    local argument_desc="$1"

    [ $# -eq 0 ]    ||  {
        # argument capture.
        :
        # Consider replace the ARGUMENT in the SKILL.md
    }

    local entrancefp=""

    if [ -d "$targetfp" ]; then
        ___x_cmd_agent_run___locate_ "$targetfp"    ||  N=agent M="Cannot locate agent.md in the folder." log:ret:64
        entrancefp="$x_"
    elif [ -f "$targetfp" ]; then
        entrancefp="$targetfp"
    fi

    # create a job like job module.
    # it could iterate .

}

___x_cmd_agent_run___locate_(){
    local targetfp="$1"

    x_="$targetfp/agent.md"
    [ ! -f "$x_" ]    ||    return 0
    x_="$targetfp/agent.md"
    [ ! -f "$x_" ]    ||    return 0
    x_="$targetfp/skill.md"
    [ ! -f "$x_" ]    ||    return 0
    x_="$targetfp/SKILL.md"
    [ ! -f "$x_" ]    ||    return 0
    x_="$targetfp/AGENT.md"
    [ ! -f "$x_" ]    ||    return 0
    x_="$targetfp/CLAUDE.md"
    [ ! -f "$x_" ]    ||    return 0
    x_="$targetfp/CODEX.md"
    [ ! -f "$x_" ]    ||    return 0
    x_="$targetfp/GEMINI.md"
    [ ! -f "$x_" ]    ||    return 0

    return 1
}
