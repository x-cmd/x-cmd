# shellcheck shell=dash disable=SC2120

___x_cmd_agent_setup(){
    [ $# -gt 0 ]    ||  set -- --help

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)  ___x_cmd help -m agent setup "$@" ; return 0 ;;
            # --all)      mode="all" ; shift ;;
            # --claude)   mode="$mode claude" ; shift ;;
            # --codex)    mode="$mode codex"  ; shift ;;
            # --gemini)   mode="$mode gemini" ; shift ;;
            *)          break ;;
        esac
    done

    local prompt='Load x-cmd with `. ~/.x-cmd.root/X` (required before using `x`), then `x -h` for help. Docs: https://www.x-cmd.com/llms.txt'

    local homefp="$HOME/AGENTS.md"

    if [ ! -f "$homefp" ]; then
        ___x_cmd fprintf "$homefp" "%s\n" "$prompt"
        return $?
    fi

    agent:info                      \
        --tip   "x agent unify"     \
        "Consider unifying the ~/CLAUDE.md ~/.codex/AGENTS.md ~/.gemini/GEMINI.md into one file."

    # if ___x_cmd_cmds grep -q "$prompt"<"$homefp" 2>/dev/null; then
    #     agent:info "Exit because previously existed in $homefp"
    #     return 0
    # fi


    # if [ -f "$CLAUDE_FP" ]; then
    #     if ___x_cmd_cmds grep -q "$prompt"<"$CLAUDE_FP" 2>/dev/null; then
    #         agent:info "Exit because previously existed in $CLAUDE_FP"
    #         return 0
    #     fi
    # fi

    # if [ -f "$CODEX_FP" ]; then
    #     if ___x_cmd_cmds grep -q "$prompt"<"$CODEX_FP" 2>/dev/null; then
    #         agent:info "Exit because previously existed in $CODEX_FP"
    #         return 0
    #     fi
    # else
    #     :
    # fi

    # if [ -f "$HOME/.gemini/GEMINI.md" ]; then
    #     :
    # else
    #     :
    # fi
}

