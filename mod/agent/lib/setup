# shellcheck shell=dash disable=SC2120

___x_cmd_agent_setup(){

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)  ___x_cmd help -m agent setup "$@" ; return 0 ;;
            # --all)      mode="all" ; shift ;;
            # --claude)   mode="$mode claude" ; shift ;;
            # --codex)    mode="$mode codex"  ; shift ;;
            # --gemini)   mode="$mode gemini" ; shift ;;
            *)          break ;;
        esac
    done

    # local prompt='Load x-cmd with `. ~/.x-cmd.root/X` (required before using `x`), then `x nihao --llmstxt` to explore usage. Docs: https://www.x-cmd.com/llms.txt'

    local prompt='Load x-cmd first before using `x`: `. ~/.x-cmd.root/X`. Then explore with `x nihao --llmstxt` or discover more skills via `x skill`.'

    # local prompt1='Load x-cmd with `. ~/.x-cmd.root/X` (required before using `x`)'
    # local prompt2='Run `x nihao --llmstxt` to learn more about x-cmd.'
    # local prompt3='Run `x skill` to browse available skills.'
    # local prompt="${prompt1} ${prompt2} ${prompt3}"

    local homefp="$HOME/AGENTS.md"

    if [ ! -f "$homefp" ]; then
        agent:info --prompt "$prompt" "Created AGENTS.md at $homefp"
        ___x_cmd fprintf "$homefp" "%s\n" "$prompt"
        return $?
    fi

    # Opencode and kimi will read.
    ___x_cmd_agent_setup___addskill "$___X_CMD_ROOT/.agents"

    local dir
    while read -r dir; do
        ___x_cmd_agent_setup___addskill_ln "$dir"
    done<<A
$HOME/.agents
$HOME/.claude
$HOME/.codex
$HOME/.gemini
A

    agent:info                      \
        --tip   "x agent unify"     \
        "Consider unifying the ~/CLAUDE.md ~/.codex/AGENTS.md ~/.gemini/GEMINI.md into one file."
}

___x_cmd_agent_setup___addskill(){
    local dir="$1"
    ___x_cmd mkdirp "$dir/skills"
    if [ -e "$dir/skills/x-cmd" ]; then
        ___x_cmd rmrf "$dir/skills/x-cmd"
    fi
    ___x_cmd_cmds cp -rf "$___X_CMD_ROOT_MOD/skill/lib/arsenal/x-cmd" "$dir/skills/x-cmd"
}


___x_cmd_agent_setup___addskill_ln(){
    local dir="$1"
    ___x_cmd mkdirp "$dir/skills"
    if [ -e "$dir/skills/x-cmd" ]; then
        ___x_cmd rmrf "$dir/skills/x-cmd"
    fi
    ___x_cmd_cmds ln -s "$___X_CMD_ROOT/.agents/skills/x-cmd" "$dir/skills/x-cmd"
    # Gitbash will use copy in 'ln -s' . It is fine.
}
