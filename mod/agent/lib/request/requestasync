# shellcheck shell=dash

___x_cmd_agent_requestasync(){
    local stderrfile="/dev/null"
    local stdoutfile="/dev/null"
    [ "$#" -gt 0 ] || set -- --help
    while [ "$#" -gt 0 ]; do
        case "$1" in
            -h|--help)
                ___x_cmd help -m agent requestasync; return 0
                ;;
            --stderr-file)
                stderrfile="$2"; arg:2:shift;
                ___x_cmd ensurefp "$stderrfile"
                ;;
            --stdout-file)
                stdoutfile="$2"; arg:2:shift;
                ___x_cmd ensurefp "$stdoutfile"
                ;;
            *)  break ;;
        esac
    done

    ( ___x_cmd_agent_request "$@" >"$stdoutfile" 2>"$stderrfile" & )
}
