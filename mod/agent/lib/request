___x_cmd_agent_request(){
    # local retry=1

    local harness=""
    local filelist=""
    local NL="$___X_CMD_UNSEENCHAR_NEWLINE"

    [ "$#" -gt 0 ] || set -- --help
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)      ___x_cmd help -m agent request "$@" ; return 0 ;;

            --harness)      harness="$2"  ;     arg:2:shift ;;
            --file)         filelist="${filelist}${NL}${2}" ; arg:2:shift ;;
            --output)       output="$2"   ;     arg:2:shift ;;

            # --retry)        retry="$2" ; arg:2:shift ;;

            --)             shift; break ;;
            *)              break ;;
        esac
    done

    local x_=""
    if [ -z "$harness" ]; then
        x_=""; ___x_cmd_agent_harness_
        harness="$x_"
    fi

    local content ;

    while read -r f; do
        [ -f "$f" ]  || continue

        content="${content}
=== filename -> $f
$(___x_cmd_cmds cat "$f")
===
"
    done <<A
$filelist
A

    local IFS=" " ; content="${content}${NL}${*}${NL}"

    if [ -z "$output" ]; then
        x_=""; ___x_cmd_agent_request___run_
        case $? in
            130)    return 130 ;;
            0)      printf "%s\n" "$x_"; return 0 ;;
            *)      return $? ;;
        esac
    fi

    content="${content}
Please output the content between two === as following:
===
<content>
===
"

    if [ -f "$output" ]; then
        ___x_cmd bakman backup "$output"
    fi

    ___x_cmd_agent_request___run_ || \
    case $? in
        130)    return 130 ;;
        0)      ;;
        *)      return $? ;;
    esac

    x_="${x_#*===}"
    x_="${x_#"$___X_CMD_UNSEENCHAR_NEWLINE"}"
    x_="${x_%===*}"
    ___x_cmd fprintf "$output" "%s" "$x_"
}

___x_cmd_agent_request___run_(){
    agent:info "Sending request to $harness ..."
    case "$harness" in
        kimi-cli)       x_="$(___x_cmd kimi -- -c "$content")" ;;
        claude)         x_="$(___x_cmd claude -- -p "$content")" ;;
        codex)          x_="$(___x_cmd codex -- exec "$content" 2>/dev/null)" ;;
        gemini-cli)     x_="$(___x_cmd gemini cli -- "$content")" ;;
        opencode)
                        if ! ___x_cmd_hascmd opencode; then
                            agent:info "Installing opencode..."
                            ___x_cmd env use opencode || return $?
                        fi
                        x_="$(___x_cmd_cmds opencode run "$content")" ;;
        "")             N=agent M="Please specify harness" log:ret:64 ;;
        *)              N=agent M="Unsupported harness -> $harness" log:ret:1 ;;
    esac
}
