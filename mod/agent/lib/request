___x_cmd_agent_request(){
    # local retry=1

    local harness=""
    local filelist=""

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)      ___x_cmd help -m agent request "$@" ; return 0 ;;

            --harness)      harness="$2"  ;     arg:2:shfit ;;
            --file)         filelist="$2" ;     arg:2:shift ;;
            --output)       output="$2"   ;     arg:2:shift ;;

            # --retry)        retry="$2" ; arg:2:shift ;;

            --)             shift; break ;;
            *)              break ;;
        esac
    done

    local content ;

    while read -r f; do
        [ -f "$f" ]  || continue

        content="
=== filename -> $f
$(___x_cmd_cmds cat "$f")
===

$content
"

    done <<A
$filelist
A

    local x_
    local IFS=" " ; content="$*"

    if [ -z "$output" ]; then
        ___x_cmd_agent_request___run_
        return $?
    fi

    content="
Please output the content between two === as following:
===
<content>
===
"

    if [ -f "$output" ]; then
        ___x_cmd bak "$output"
    fi

    ___x_cmd_agent_request___run_ || \
    case $? in
        130)    return 130 ;;
        0)      ;;
        *)      return $? ;;
    esac

    x_="${x_#*===}"
    x_="${x_#"$___X_CMD_UNSEENCHAR_NEWLINE"}"
    x_="${x_%===*}"
    ___x_cmd fprintf "$output" "%s" "$x_"
}

___x_cmd_agent_request___run_(){
    case "$harness" in
        kimi-cli)       x_="$(___x_cmd kimi     -c "$content")" ;;
        claude)         x_="$(___x_cmd claude   -p "$content")" ;;
        *)              N=agent M="Unsupported harness -> $harness" log:ret:1 ;;
    esac
}
