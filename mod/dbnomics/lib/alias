        core.inflation)         x_=PCPIEPCH.pcent_change           ;;
        employment)             x_=LE.persons                      ;;
        output.gap)             x_=NGAP_NPGDP.pcent_potential_gdp  ;;
        gdp.deflator)           x_=NGDP_D.idx                      ;;
        ppp.pc.real)            x_=NGDPRPPPPC.purchasing_power_parity_2017_international_dollar ;;
        ppp.share)              x_=PPPSH.pcent                     ;;
        gov.net.debt)           x_=GGXWDN.national_currency        ;;
        gov.net.debt.gdp)       x_=GGXWDN_NGDP.pcent_gdp           ;;
        gov.balance)            x_=GGXCNL.national_currency        ;;
