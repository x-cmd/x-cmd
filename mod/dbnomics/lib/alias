        gov.net.lending.gdp)    x_=GGSB_NPGDP.pcent_potential_gdp ;;
        savings)                x_=NGSD_NGDP.pcent_gdp             ;;
        investment)             x_=NID_NGDP.pcent_gdp              ;;
        exports)                x_=TX_RPCH.pcent_change            ;;
        imports)                x_=TM_RPCH.pcent_change            ;;
