# shellcheck shell=dash
# Alias table: human-readable alias → provider/dataset/series
# Remote: https://codeberg.org/x-cmd/data/raw/branch/main/alias/dbnomics.alias.tsv
# Local:  $___X_CMD_ROOT_DATA/data/alias/dbnomics.alias.tsv

___X_CMD_DBNOMICS_ALIAS_URL="https://codeberg.org/x-cmd/data/raw/branch/main/alias/dbnomics.alias.tsv"

___x_cmd_dbnomics_alias___cache(){
    printf '%s' "${___X_CMD_ROOT_DATA}/data/alias/dbnomics.alias.tsv"
}

___x_cmd_dbnomics_alias___download(){
    local cache; cache="$(___x_cmd_dbnomics_alias___cache)"
    local dir; dir="$(dirname "$cache")"
    mkdir -p "$dir"
    ___x_cmd curl -sS -L -f "$___X_CMD_DBNOMICS_ALIAS_URL" > "$cache" 2>/dev/null
}

___x_cmd_dbnomics_alias___load(){
    [ -n "${___x_cmd_dbnomics_alias_table:-}" ] && return 0
    local cache; cache="$(___x_cmd_dbnomics_alias___cache)"
    if [ ! -f "$cache" ]; then
        ___x_cmd_dbnomics_alias___download || {
            M='Failed to download alias table from remote' N=dbnomics log:ret:1
        }
    fi
    [ -s "$cache" ] || { M='Alias cache is empty' N=dbnomics log:ret:1; }
    ___x_cmd_dbnomics_alias_table="$(cat "$cache")"
}

# List all aliases (or filter by keyword).
___x_cmd_dbnomics_alias___list(){
    local q="${1:-}"
    ___x_cmd_dbnomics_alias___load || return 1
    printf '%s' "$___x_cmd_dbnomics_alias_table" \
        | awk -F'\t' -v q="$q" '
            NR==1 { next }
            q == "" || $1 ~ q || $5 ~ q {
                printf "%s\t%s/%s/%s\t%s\n", $1, $2, $3, $4, $5
            }
        '
}

# Dynamic alias: imf.<cc>.<series> → IMF/WEO:2024-10/<C3>.<WEO_SUBJECT>
# Falls back to alias table lookup if pattern doesn't match.
___x_cmd_dbnomics_alias___resolve(){
    local alias="$1"

    # Try dynamic pattern first
    local _dynamic
    _dynamic="$(___x_cmd_dbnomics_alias___resolve_dynamic "$alias")"
    if [ -n "$_dynamic" ]; then
        printf '%s' "$_dynamic"
        return 0
    fi

    # Fallback to alias table
    ___x_cmd_dbnomics_alias___load || return 1
    printf '%s' "$___x_cmd_dbnomics_alias_table" \
        | awk -F'\t' -v a="$alias" '
            NR==1 { next }
            $1 == a { printf "%s/%s/%s", $2, $3, $4; exit 0 }
        '
}

# Map group alias to WEOAGG numeric code
___x_cmd_dbnomics_alias___group_to_weoagg_(){
    local grp="$1"
    case "$grp" in
        world)      x_=001 ;;
        advanced)   x_=110 ;;
        g7)         x_=119 ;;
        euro)       x_=163 ;;
        eu)         x_=998 ;;
        emerging)   x_=200 ;;
        latam)      x_=205 ;;
        mideast)    x_=400 ;;
        devasia)    x_=505 ;;
        asean)      x_=510 ;;
        africa)     x_=603 ;;
        deveur)     x_=903 ;;
        *)          return 1 ;;
    esac
}

