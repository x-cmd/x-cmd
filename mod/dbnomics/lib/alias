        cpi)                    x_=PCPI.idx                       ;;
        inflation)              x_=PCPIPCH.pcent_change            ;;
        unemployment)           x_=LUR.pcent_total_labor_force     ;;
        gdp)                    x_=NGDPD.us_dollars                ;;
