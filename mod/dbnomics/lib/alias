# Map UNCTAD indicator suffix to indicator name
___x_cmd_dbnomics_alias___unctad_suffix_(){
    local suffix="$1"
    case "$suffix" in
        # Expenditure approach
        gdp)              x_=gross-domestic-product-gdp ;;
        consumption)      x_=household-consumption-expenditure-including-npish ;;
        gov)              x_=general-government-final-consumption-expenditure ;;
        investment)       x_=gross-capital-formation ;;
        fixed)            x_=gross-fixed-capital-formation ;;
        inventory)        x_=changes-in-inventories ;;
        exports)          x_=exports-of-goods-and-services ;;
        imports)          x_=imports-of-goods-and-services ;;
        # Production approach (value added)
        agri)             x_=agriculture-hunting-forestry-fishing ;;
        mining)           x_=mining-manufacturing-utilities ;;
        manufacturing)    x_=manufacturing ;;
        construction)     x_=construction ;;
        trade)            x_=wholesale-retail-trade-restaurants-and-hotels ;;
        transport)         x_=transport-storage-and-communications ;;
        services)         x_=services ;;
        other)            x_=other-activities ;;
        total-va)         x_=total-value-added ;;
        *)                return 1 ;;
    esac
}

# Resolve unctad.<cc>.<indicator> → UNCTAD/GDPGBTOEVBKOEATASA/A.percentage-of-gross-domestic-product.<country>.<indicator>
___x_cmd_dbnomics_alias___resolve_unctad(){
    local alias="$1"; local x_=""
    local rest="${alias#unctad.}"
    [ "$rest" = "$alias" ] && return 1

    local cc="${rest%%.*}"
    local suffix="${rest#*.}"

    ___x_cmd_dbnomics_alias___c2tounctad_ "$cc" || return 1
    local country="$x_"

    ___x_cmd_dbnomics_alias___unctad_suffix_ "$suffix" || return 1
    local indicator="$x_"

    printf 'UNCTAD/GDPGBTOEVBKOEATASA/A.percentage-of-gross-domestic-product.%s.%s' "$country" "$indicator"
}

# Resolve bis.rate.<cc> → BIS/WS_CBPOL/M.<REF_AREA>
# e.g. bis.rate.us → US federal funds rate
___x_cmd_dbnomics_alias___resolve_cbpol(){
    local alias="$1"; local x_=""
    local cc="${alias#bis.rate.}"
    [ -n "$cc" ] || return 1
    ___x_cmd_dbnomics_alias___cc_to_cbpol_ "$cc" || return 1
    printf 'BIS/WS_CBPOL/M.%s' "$x_"
}

