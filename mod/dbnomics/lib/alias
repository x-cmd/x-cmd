        gdp.pc)                 x_=NGDPDPC.us_dollars              ;;
        population)             x_=LP.persons                      ;;
        gov.debt)               x_=GGXWDG.national_currency         ;;
        gov.debt.gdp)           x_=GGXWDG_NGDP.pcent_gdp           ;;
        gov.revenue)            x_=GGR.national_currency            ;;
        gov.revenue.gdp)        x_=GGR_NGDP.pcent_gdp             ;;
