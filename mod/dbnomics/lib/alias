        *)                      return 1                            ;;
    esac
}

# Resolve imf.<cc>.<series> dynamically
___x_cmd_dbnomics_alias___resolve_dynamic(){
    local alias="$1"; local x_=""
    case "$alias" in
        imf.*.*)
            local cc="${alias#imf.}"
            local suffix="${cc#*.}"
            cc="${cc%%.*}"
            # Check if cc is a WEOAGG group code first
            ___x_cmd_dbnomics_alias___group_to_weoagg_ "$cc" && {
                local grp="$x_"
                ___x_cmd_dbnomics_alias___series_suffix_ "$suffix" || return 1
                printf 'IMF/WEOAGG:2024-10/%s.%s' "$grp" "$x_"
                return 0
            }
            # Fallback to country code
            ___x_cmd_dbnomics_alias___c2toweo_ "$cc" || return 1
            local weo="$x_"
            ___x_cmd_dbnomics_alias___series_suffix_ "$suffix" || return 1
            local subject="$x_"
            printf 'IMF/WEO:2024-10/%s.%s' "$weo" "$subject"
            ;;
        unctad.*)
            ___x_cmd_dbnomics_alias___resolve_unctad "$alias"
            ;;
        bis.rate.*)
            ___x_cmd_dbnomics_alias___resolve_cbpol "$alias"
            ;;
        bis.*)
            ___x_cmd_dbnomics_alias___resolve_bis "$alias"
            ;;
        *)  return 1 ;;
    esac
}

# Map currency code (3-letter) to BIS country.currency pair
___x_cmd_dbnomics_alias___currency_to_bis_(){
    local cur="$1"
    case "$cur" in
        usd) x_=US.USD ;; eur) x_=DE.EUR ;; gbp) x_=GB.GBP ;; jpy) x_=JP.JPY ;;
        cny) x_=CN.CNY ;; aud) x_=AU.AUD ;; cad) x_=CA.CAD ;; krw) x_=KR.KRW ;;
        sgd) x_=SG.SGD ;; thb) x_=TH.THB ;; myr) x_=MY.MYR ;; inr) x_=IN.INR ;;
        hkd) x_=HK.HKD ;; twd) x_=TW.TWD ;; php) x_=PH.PHP ;; mxn) x_=MX.MXN ;;
        rub) x_=RU.RUB ;; zar) x_=ZA.ZAR ;; try) x_=TR.TRY ;; sek) x_=SE.SEK ;;
        nok) x_=NO.NOK ;; chf) x_=CH.CHF ;; nzd) x_=NZ.NZD ;; *) return 1 ;;
    esac
}

# Resolve bis.<currency3> → BIS/WS_XRU/M.<country>.<currency>.A
# e.g. bis.eur → EUR/USD → M.DE.EUR.A
___x_cmd_dbnomics_alias___resolve_bis(){
    local alias="$1"; local x_=""
    local cur="${alias#bis.}"
    [ -n "$cur" ] || return 1
    ___x_cmd_dbnomics_alias___currency_to_bis_ "$cur" || return 1
    printf 'BIS/WS_XRU/M.%s.A' "$x_"
}

