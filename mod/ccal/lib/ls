
___x_cmd_ccal_ls(){
    local mode=auto
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)          ___x_cmd help -m ccal ls "$@"; return 0 ;;
            --tsv|--csv|--tty|--yml|--auto)
                                    mode="${1#--}" ;;
            *)                      break ;;
        esac
        shift
    done

    # Auto-detect mode for ls
    if [ "$mode" = auto ]; then
        if ___x_cmd_is_stdout2tty; then
            mode=tty
        else
            mode=tsv
        fi
    fi

    local input="${1:-today}"

    ___x_cmd_ccal_lunar_prepare || return $?
    ___x_cmd_ccal_lunar_prepare_index || return $?

    case "$input" in
        t|today)
            # Default: show current month
            input="$(___x_cmd_cmds date +%Y-%m)"
            ___x_cmd_ccal_ls___month "$input" "$mode"
            ;;
        *-*-*)
            # Specific date -> show info-like for that day
            if [ "$mode" = tty ]; then
                # TTY mode: show single day in table format (not full month calendar)
                ___x_cmd_ccal_ls___day "$input" tty
            else
                ___x_cmd_ccal_info "$input" "$mode"
            fi
            ;;
        *-*)
            ___x_cmd_ccal_ls___month "$input" "$mode"
            ;;
        *)
            # x ccal ls 2026 -> show all 12 months of 2026
            ___x_cmd_ccal_ls___year_months "$input" "$mode"
            ;;
    esac
}

