___x_cmd_ccal_ls___day_data(){
    local ymd="$1"
    local y="$2"
    local m="$3"

    # Parse the target date components
    local d="${ymd##*-}"
    local m_without_d="${ymd%-$d}"
    local m_num="${m_without_d#*-}"
    m_num="${m_num#0}"
    d="${d#0}"

    # Read 3 months of data to cover ±7 days (spans at most 1 month)
    # prev-month, current, next-month
    local pm py nm ny
    if [ "$m_num" -eq 1 ]; then
        pm=12; py=$((y - 1))
    else
        pm=$((m_num - 1)); py=$y
    fi
    if [ "$m_num" -eq 12 ]; then
        nm=1; ny=$((y + 1))
    else
        nm=$((m_num + 1)); ny=$y
    fi

    {
        ___x_cmd_ccal_lunar_cat "$py" "$pm" --tsv 2>/dev/null
        ___x_cmd_ccal_lunar_cat "$y" "$m_num" --tsv 2>/dev/null
        ___x_cmd_ccal_lunar_cat "$ny" "$nm" --tsv 2>/dev/null
    } | ___x_cmd_cmds awk -v "y=$y" -v "m=$m_num" -v "d=$d" -F '\t' '
        function date2int(s, a) {
            split(s, a, "-")
            return a[1]*10000 + a[2]*100 + a[3]
        }
        # Days in month - proper lookup
        function daysInMonth(y, m) {
            if (m == 2) return (y % 4 == 0 && (y % 100 != 0 || y % 400 == 0)) ? 29 : 28
            if (m == 4 || m == 6 || m == 9 || m == 11) return 30
            return 31
        }
        # Add days to date
        function addDays(y, m, d, n, ny, nm, nd) {
            nd = d + n
            nm = m
            ny = y
            while (nd > daysInMonth(ny, nm)) {
                nd -= daysInMonth(ny, nm)
                nm++
                if (nm > 12) { ny++; nm = 1 }
            }
            while (nd < 1) {
                nm--
                if (nm < 1) { ny--; nm = 12 }
                nd += daysInMonth(ny, nm)
            }
            return sprintf("%04d-%02d-%02d", ny, nm, nd)
        }
        NR==1 { next }
        {
            di = date2int($1)
            start = addDays(y, m, d, -7)
            end = addDays(y, m, d, 7)
            rsi = date2int(start)
            rei = date2int(end)
            if (di >= rsi && di <= rei) print
        }
    '
}
